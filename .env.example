# Build-time credentials for KM0 Cloud user count (/cloud/ page).
# Copy to .env and fill in values. Never commit .env.
#
# CLOUD_APP_TOKEN is an OpenCloud app token with user read access.
# It expires after 12 months; renew in OpenCloud admin and update .env before rebuild.
#
# Used at `npm run build` and `docker compose build` (via build args from this file).
CLOUD_ADMIN_USER=
CLOUD_APP_TOKEN=

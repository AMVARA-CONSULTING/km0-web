# GitHub + autoagents (optional — copy to .env, never commit)

# Fine-grained PAT for Luipy56 — Issues: Read and write (comments, labels, close)
# GH_TOKEN=github_pat_...

AGENT_GH_REPO=AMVARA-CONSULTING/km0-web
AGENT_GIT_BRANCH=main

# Committer: 1 = full committer via cursor-agent (040-committer.md)
AGENT_COMMITTER_USE_CURSOR=1

# Runtime digest and gh stderr (inside repo; do not use /tmp)
# AGENT_LOOP_TMP=autoagents/.runtime

# KM0 Digital - static landing (Docker :9180)
# Primary hostname: km0digital.com

server {
    listen 80;
    listen [::]:80;
    server_name km0digital.com www.km0digital.com km0.amvara.de;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
        try_files $uri =404;
    }

    location / {
        if ($host = km0.amvara.de) {
            return 301 https://km0digital.com$request_uri;
        }
        if ($host = www.km0digital.com) {
            return 301 https://km0digital.com$request_uri;
        }
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name km0digital.com;

    ssl_certificate     /etc/letsencrypt/live/km0digital.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/km0digital.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    client_max_body_size 1m;

    location = /hooks/ideas {
        proxy_pass http://127.0.0.1:9181/hooks/ideas;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 16k;
        # Optional: limit_req zone=ideas burst=5 nodelay; (requires limit_req_zone in http {})
    }

    location / {
        proxy_pass http://127.0.0.1:9180;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name km0.amvara.de;

    ssl_certificate     /etc/letsencrypt/live/km0.amvara.de/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/km0.amvara.de/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    return 301 https://km0digital.com$request_uri;
}

---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { fetchCloudUserCount } from '../lib/cloud-users';

interface Props {
  locale: Locale;
  messages: Messages;
  /** `band` embeds under Offer; `section` is a standalone block (unused on home). */
  variant?: 'band' | 'section';
}

const { locale, messages: m, variant = 'band' } = Astro.props;
const countResult = await fetchCloudUserCount();

const countLocale =
  locale === 'de' ? 'de-DE' : locale === 'en' ? 'en-GB' : locale === 'ca' ? 'ca-ES' : 'es-ES';

const isBand = variant === 'band';
---

{
  isBand ? (
    <aside
      id="cloud-users"
      class="cloud-user-proof"
      aria-labelledby="cloud-users-heading"
      data-reveal
      data-delay="200"
    >
      <h2 id="cloud-users-heading" class="sr-only">
        {m.cloudUsers.countLabel}
      </h2>
      {countResult.ok ? (
        <p class="cloud-user-proof__line" aria-live="polite">
          <span
            class="cloud-user-proof__count tabular-nums"
            aria-label={m.cloudUsers.countAria.replace('{count}', String(countResult.count))}
          >
            {countResult.count.toLocaleString(countLocale)}
          </span>
          <span class="cloud-user-proof__label">{m.cloudUsers.countLabel}</span>
        </p>
      ) : (
        <p class="cloud-user-proof__unavailable">{m.cloudUsers.unavailable}</p>
      )}
    </aside>
  ) : (
    <section id="cloud-users" class="section-pad bg-navy text-white" aria-labelledby="cloud-users-heading">
      <div class="mx-auto max-w-6xl">
        <h2 id="cloud-users-heading" class="sr-only">
          {m.cloudUsers.countLabel}
        </h2>
        <div class="mx-auto max-w-sm" data-reveal>
          {countResult.ok ? (
            <p
              class="cloud-user-stat-count tabular-nums text-center"
              aria-live="polite"
              aria-label={m.cloudUsers.countAria.replace('{count}', String(countResult.count))}
            >
              {countResult.count.toLocaleString(countLocale)}
            </p>
          ) : (
            <p class="text-center text-base text-white/70">{m.cloudUsers.unavailable}</p>
          )}
          <p class="mt-3 text-center font-sans text-xs font-medium uppercase tracking-[0.12em] text-white/55">
            {m.cloudUsers.countLabel}
          </p>
        </div>
      </div>
    </section>
  )
}

<style>
  .cloud-user-proof {
    margin-top: 3rem;
    padding: 1.75rem 0 0;
    border-top: 1px solid var(--color-mist);
  }

  .cloud-user-proof__line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem 1.25rem;
    margin: 0;
  }

  .cloud-user-proof__count {
    font-family: theme('fontFamily.display');
    font-size: clamp(2.75rem, 8vw, 4rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-signal);
  }

  .cloud-user-proof__label {
    max-width: 14rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-ink) 55%, transparent);
  }

  .cloud-user-proof__unavailable {
    margin: 0;
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-ink) 55%, transparent);
  }

  .cloud-user-stat-count {
    font-family: theme('fontFamily.display');
    font-size: clamp(3rem, 12vw, 4.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: #0f766e;
  }
</style>

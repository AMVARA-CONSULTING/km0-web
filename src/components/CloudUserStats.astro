---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { fetchCloudUserCount } from '../lib/cloud-users';

interface Props {
  locale: Locale;
  messages: Messages;
  /** `band` = intentional Ink proof on home; `section` = standalone dark block. */
  variant?: 'band' | 'section';
}

const { locale, messages: m, variant = 'band' } = Astro.props;
const countResult = await fetchCloudUserCount();

const countLocale =
  locale === 'de' ? 'de-DE' : locale === 'en' ? 'en-GB' : locale === 'ca' ? 'ca-ES' : 'es-ES';

const cloudItem = m.services.items.find((item) => item.id === 'cloud');
const cloudHref = cloudItem?.url ?? 'https://cloud.km0digital.com';
const registerHref = 'https://auth.km0digital.com/register?service=cloud';
const cloudCta = cloudItem?.secondaryCta ?? m.hero.ctaPrimary;

const isBand = variant === 'band';
const formattedCount = countResult.ok
  ? countResult.count.toLocaleString(countLocale)
  : '';
---

{
  isBand ? (
    <aside
      id="cloud-users"
      class="section-pad cloud-proof surface-ink"
      aria-labelledby="cloud-users-heading"
    >
      <div class="cloud-proof__inner mx-auto max-w-6xl">
        <div class="cloud-proof__stat" data-reveal>
          <h2 id="cloud-users-heading" class="sr-only">
            {m.cloudUsers.countLabel}
          </h2>
          {countResult.ok ? (
            <div class="cloud-proof__stack" aria-live="polite">
              <p
                class="cloud-proof__count tabular-nums"
                data-cloud-user-count
                data-target={String(countResult.count)}
                data-locale={countLocale}
                aria-label={m.cloudUsers.countAria.replace('{count}', String(countResult.count))}
              >
                {formattedCount}
              </p>
              <p class="cloud-proof__label">{m.cloudUsers.countLabel}</p>
            </div>
          ) : (
            <p class="cloud-proof__unavailable">{m.cloudUsers.unavailable}</p>
          )}
        </div>
        <div class="cloud-proof__actions" data-reveal data-delay="100">
          <a href={registerHref} class="btn-primary cloud-proof__cta">
            {m.cloudUsers.registerCta}
          </a>
          <a href={cloudHref} class="cloud-proof__register">
            {cloudCta}
          </a>
        </div>
      </div>
    </aside>
  ) : (
    <section id="cloud-users" class="section-pad surface-ink" aria-labelledby="cloud-users-heading">
      <div class="mx-auto max-w-6xl">
        <h2 id="cloud-users-heading" class="sr-only">
          {m.cloudUsers.countLabel}
        </h2>
        <div class="mx-auto max-w-sm cloud-user-section" data-reveal>
          {countResult.ok ? (
            <p
              class="cloud-user-stat-count tabular-nums"
              data-cloud-user-count
              data-target={String(countResult.count)}
              data-locale={countLocale}
              aria-live="polite"
              aria-label={m.cloudUsers.countAria.replace('{count}', String(countResult.count))}
            >
              {formattedCount}
            </p>
          ) : (
            <p class="text-center text-base text-white/70">{m.cloudUsers.unavailable}</p>
          )}
          <p class="cloud-user-stat-label">{m.cloudUsers.countLabel}</p>
        </div>
      </div>
    </section>
  )
}

<style>
  /* Intentional Ink proof band (earned; not zebra). Sacred live counter + Cloud CTA. */
  .cloud-proof {
    color: var(--color-on-ink);
  }

  .cloud-proof__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.75rem 3rem;
  }

  .cloud-proof__stat {
    min-width: 0;
    flex: 1 1 14rem;
  }

  /* Stacked hierarchy: loud digits own the row; label is secondary under them. */
  .cloud-proof__stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
    margin: 0;
  }

  .cloud-proof__count {
    margin: 0;
    font-family: theme('fontFamily.display');
    font-size: clamp(3.5rem, 11vw, 5.75rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.055em;
    color: var(--color-signal-hover);
    opacity: 0;
    transform: translate3d(0, 0.4rem, 0);
  }

  .cloud-proof__stat.is-visible .cloud-proof__count {
    animation: cloud-proof-count-in var(--duration-hero-capacity) var(--ease-out-expo) both;
  }

  .cloud-proof__label {
    margin: 0;
    max-width: 18rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1.35;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-on-ink) 58%, transparent);
    opacity: 0;
    transform: translate3d(0, 0.25rem, 0);
  }

  .cloud-proof__stat.is-visible .cloud-proof__label {
    animation: cloud-proof-count-in var(--duration-hero-capacity) var(--ease-out-expo) 60ms both;
  }

  .cloud-proof__unavailable {
    margin: 0;
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-on-ink) 65%, transparent);
  }

  .cloud-proof__actions {
    flex-shrink: 0;
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.65rem;
  }

  .cloud-proof__cta {
    flex-shrink: 0;
  }

  .cloud-proof__register {
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-on-ink) 72%, transparent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-signal-hover) 45%, transparent);
    text-underline-offset: 0.18em;
    transition: color 0.3s var(--ease-out-expo), text-decoration-color 0.3s var(--ease-out-expo);
  }

  .cloud-proof__register:hover {
    color: var(--color-signal-hover);
    text-decoration-color: var(--color-signal-hover);
  }

  .cloud-proof__register:focus-visible {
    outline: 2px solid var(--color-signal-hover);
    outline-offset: 3px;
  }

  /* Mobile: deliberate stack, count first, CTA second (no ragged wrap). */
  @media (max-width: 639px) {
    .cloud-proof__inner {
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: stretch;
      gap: 1.5rem;
    }

    .cloud-proof__stat {
      flex: none;
    }

    .cloud-proof__actions {
      align-self: flex-start;
    }
  }

  @keyframes cloud-proof-count-in {
    from {
      opacity: 0;
      transform: translate3d(0, 0.4rem, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cloud-proof__count,
    .cloud-proof__label {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  /* Section variant: same loud digit energy, centered. */
  .cloud-user-section {
    text-align: center;
  }

  .cloud-user-stat-count {
    margin: 0;
    font-family: theme('fontFamily.display');
    font-size: clamp(3.5rem, 12vw, 5.5rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.055em;
    color: var(--color-signal-hover);
  }

  .cloud-user-stat-label {
    margin: 0.55rem 0 0;
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-on-ink) 55%, transparent);
  }
</style>

<script>
  import '../scripts/hero-capacity.ts';
</script>

---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
/** Same group URL as Contact (do not invent a second invite). */
const WHATSAPP_GROUP_URL = 'https://chat.whatsapp.com/DtU6nBk2KxXJhmZbW94nFs';
---

<section id="community" class="section-pad community" aria-labelledby="community-heading">
  <div class="mx-auto max-w-6xl">
    <div class="community__inner" data-reveal>
      <h2 id="community-heading" class="heading-section text-navy">
        {m.community.heading}
      </h2>
      <p class="community__intro">{m.community.intro}</p>
      <nav class="community__actions" aria-label={m.community.heading}>
        <a href={localeHref(locale, '/meeting/')} class="community__cta">
          {m.nav.meeting}
        </a>
        <a
          href={WHATSAPP_GROUP_URL}
          class="community__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          {m.community.whatsappLink}
        </a>
        <a href={localeHref(locale, '/ideas/')} class="community__link">
          {m.community.ideasLink}
        </a>
      </nav>
    </div>
  </div>
</section>

<style>
  .community__inner {
    max-width: 36rem;
    border-left: 3px solid var(--color-signal);
    padding-left: 1.5rem;
  }

  .community__intro {
    margin: 1rem 0 1.25rem;
    font-size: 1.125rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }

  .community__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem 1.35rem;
  }

  /* Quiet secondary actions - Cloud stays the primary CTA language */
  .community__cta,
  .community__link {
    display: inline-block;
    font-family: theme('fontFamily.sans');
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: rgb(15 118 110 / 0.4);
    text-underline-offset: 0.2em;
  }

  .community__link {
    font-weight: 500;
    text-decoration-color: color-mix(in srgb, var(--color-signal) 35%, transparent);
  }

  .community__cta:hover,
  .community__link:hover {
    color: var(--color-signal);
    text-decoration-color: var(--color-signal);
  }

  .community__cta:focus-visible,
  .community__link:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 4px;
  }
</style>

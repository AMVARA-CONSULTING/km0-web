---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { withHash, localeHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const delays = [0, 60, 120, 180, 240, 300];
---

<section id="community" class="section-pad bg-surface">
  <div class="mx-auto max-w-6xl text-center">
    <p data-reveal class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.community.eyebrow}
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-6 text-navy">
      {m.community.heading}
    </h2>
    <p data-reveal data-delay="120" class="mx-auto mb-12 max-w-2xl text-lg text-navy/70">
      {m.community.intro}
    </p>

    <div class="mb-12 flex flex-wrap justify-center gap-3 md:gap-4">
      {
        m.community.audiences.map((label, i) => (
          <span
            data-reveal
            data-delay={String(delays[i] ?? 0)}
            class="chip text-sm md:text-base"
          >
            {label}
          </span>
        ))
      }
    </div>

    <p
      data-reveal
      data-delay="360"
      class="mx-auto mb-12 max-w-2xl text-base leading-relaxed text-navy/60 md:text-lg"
    >
      {m.community.humanNote}
    </p>

    <div data-reveal data-delay="440" class="flex flex-wrap justify-center gap-4">
      <a href={withHash(locale, 'contact')} class="btn-primary">{m.community.ctaPrimary}</a>
      <a
        href={localeHref(locale, '/doc/')}
        class="inline-flex items-center justify-center rounded-full border border-navy/15 px-8 py-3 text-sm font-medium text-navy transition-all duration-500 ease-apple hover:border-navy/30 hover:bg-white"
      >
        {m.community.ctaExplore}
      </a>
    </div>
  </div>
</section>

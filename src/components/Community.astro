---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
---

<section id="community" class="section-pad community" aria-labelledby="community-heading">
  <div class="mx-auto max-w-6xl">
    <div class="community__inner" data-reveal>
      <h2 id="community-heading" class="heading-section text-navy">
        {m.community.heading}
      </h2>
      <p class="community__intro">{m.community.intro}</p>
      <a href={localeHref(locale, '/meeting/')} class="btn-primary community__cta">
        {m.nav.meeting}
      </a>
    </div>
  </div>
</section>

<style>
  .community__inner {
    max-width: 36rem;
  }

  .community__intro {
    margin: 1rem 0 1.75rem;
    font-size: 1.125rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }

  .community__cta {
    display: inline-flex;
  }
</style>

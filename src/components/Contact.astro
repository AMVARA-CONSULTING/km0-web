---
import type { Messages } from '../i18n/types';

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;

const WHATSAPP_GROUP_URL = 'https://chat.whatsapp.com/DtU6nBk2KxXJhmZbW94nFs';
---

<section id="contact" class="section-pad contact" aria-labelledby="contact-heading">
  <div class="mx-auto max-w-6xl">
    <div class="contact__inner">
      <header data-reveal>
        <h2 id="contact-heading" class="heading-section text-navy">
          {m.contact.heading}
        </h2>
        <p class="contact__body">{m.contact.body}</p>
      </header>
      <a data-reveal data-delay="80" href={`mailto:${m.contact.email}`} class="btn-primary">
        {m.contact.email}
      </a>
      <div data-reveal data-delay="160" class="contact__whatsapp">
        <p class="contact__whatsapp-label">{m.contact.whatsappLabel}</p>
        <a
          href={WHATSAPP_GROUP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="contact__qr"
          aria-label={m.contact.whatsappAria}
        >
          <p class="contact__qr-hint">{m.contact.whatsappHint}</p>
          <img
            src="/contact/whatsapp-group-qr.png"
            alt={m.contact.whatsappQrAlt}
            width="180"
            height="180"
            class="contact__qr-img"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__inner {
    max-width: 32rem;
  }

  .contact__body {
    margin: 1rem 0 1.75rem;
    font-size: 1.125rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 65%, transparent);
  }

  .contact__whatsapp {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-mist);
  }

  .contact__whatsapp-label {
    margin: 0 0 0.75rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-ink) 60%, transparent);
  }

  .contact__qr {
    display: inline-block;
    text-decoration: none;
    color: inherit;
  }

  .contact__qr:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 4px;
  }

  .contact__qr-hint {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    color: color-mix(in srgb, var(--color-ink) 50%, transparent);
  }

  .contact__qr-img {
    display: block;
    border: 1px solid var(--color-mist);
    background: var(--color-snow);
  }
</style>

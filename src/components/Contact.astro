---
import type { Messages } from '../i18n/types';

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;

const WHATSAPP_GROUP_URL = 'https://chat.whatsapp.com/DtU6nBk2KxXJhmZbW94nFs';
---

<section id="contact" class="section-pad bg-white">
  <div class="mx-auto max-w-2xl text-center">
    <p data-reveal class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.contact.eyebrow}
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-8 text-navy">
      {m.contact.heading}
    </h2>
    <p data-reveal data-delay="160" class="mb-10 text-lg text-navy/60">
      {m.contact.body}
    </p>
    <a
      data-reveal
      data-delay="240"
      href={`mailto:${m.contact.email}`}
      class="btn-primary"
    >
      {m.contact.email}
    </a>
    <div data-reveal data-delay="320" class="mt-12 border-t border-navy/10 pt-10">
      <p class="mb-4 text-sm font-medium text-navy/60">{m.contact.whatsappLabel}</p>
      <a
        href={WHATSAPP_GROUP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-block rounded-2xl border border-navy/10 bg-surface p-4 shadow-sm transition-all hover:border-navy/25 hover:shadow-md"
        aria-label={m.contact.whatsappAria}
      >
        <p class="mb-3 text-sm font-medium text-navy/50 transition-colors group-hover:text-navy/80">
          {m.contact.whatsappHint}
        </p>
        <img
          src="/contact/whatsapp-group-qr.png"
          alt={m.contact.whatsappQrAlt}
          width="200"
          height="200"
          class="mx-auto block"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</section>

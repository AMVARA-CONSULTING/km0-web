---
import type { Messages } from '../i18n/types';

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;

const WHATSAPP_GROUP_URL = 'https://chat.whatsapp.com/DtU6nBk2KxXJhmZbW94nFs';
---

<section
  id="contact"
  class="section-pad contact surface-snow surface-band km0-motif"
  aria-labelledby="contact-heading"
>
  <div class="mx-auto max-w-6xl">
    <div class="contact__grid">
      <div class="contact__lead">
        <header data-reveal>
          <h2 id="contact-heading" class="heading-section text-navy">
            {m.contact.heading}
          </h2>
          <p class="contact__body">{m.contact.body}</p>
        </header>
        <p data-reveal data-delay="80" class="contact__email">
          {m.contact.email}
        </p>
      </div>
      <div data-reveal data-delay="160" class="contact__whatsapp">
        <p class="contact__whatsapp-label">{m.contact.whatsappLabel}</p>
        <a
          href={WHATSAPP_GROUP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="contact__qr"
          aria-label={m.contact.whatsappAria}
        >
          <p class="contact__qr-hint">{m.contact.whatsappHint}</p>
          <span class="contact__qr-frame">
            <span class="contact__qr-corners" aria-hidden="true">
              <span class="contact__qr-corner" data-pos="tl"></span>
              <span class="contact__qr-corner" data-pos="tr"></span>
              <span class="contact__qr-corner" data-pos="bl"></span>
              <span class="contact__qr-corner" data-pos="br"></span>
            </span>
            <span class="contact__qr-pad">
              <img
                src="/contact/whatsapp-group-qr.png"
                alt={m.contact.whatsappQrAlt}
                width="180"
                height="180"
                class="contact__qr-img"
                loading="lazy"
                decoding="async"
              />
            </span>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact__grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
      gap: 3.5rem;
    }
  }

  .contact__lead {
    max-width: 32rem;
  }

  .contact__body {
    margin: 1rem 0 1.75rem;
    font-size: 1.125rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 65%, transparent);
  }

  .contact__email {
    margin: 0;
    font-family: theme('fontFamily.sans');
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-navy);
    word-break: break-all;
  }

  .contact__whatsapp {
    padding-top: 0;
  }

  @media (max-width: 767px) {
    .contact__whatsapp {
      margin-top: 0.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--color-mist);
    }
  }

  .contact__whatsapp-label {
    margin: 0 0 0.75rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-ink) 60%, transparent);
  }

  .contact__qr {
    display: inline-block;
    text-decoration: none;
    color: inherit;
  }

  .contact__qr:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 4px;
  }

  .contact__qr-hint {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    color: color-mix(in srgb, var(--color-ink) 50%, transparent);
  }

  /* Civic QR chrome: peers hero Cloud QR (Snow/Mist/Signal + Ink pad), Contact scale */
  .contact__qr-frame {
    position: relative;
    display: inline-block;
    padding: 0.5rem;
    background: var(--color-snow);
    border: 1px solid var(--color-mist);
    border-left: 2px solid var(--color-signal);
    transition:
      border-color 0.3s var(--ease-out-expo),
      background-color 0.3s var(--ease-out-expo);
  }

  .contact__qr:hover .contact__qr-frame {
    border-color: color-mix(in srgb, var(--color-signal) 55%, var(--color-mist));
    border-left-color: var(--color-signal);
    background: color-mix(in srgb, var(--color-signal) 5%, var(--color-snow));
  }

  .contact__qr-corners {
    position: absolute;
    inset: 0.25rem;
    pointer-events: none;
  }

  .contact__qr-corner {
    position: absolute;
    width: 0.55rem;
    height: 0.55rem;
    border-color: var(--color-signal);
    border-style: solid;
    opacity: 0.85;
  }

  .contact__qr-corner[data-pos='tl'] {
    top: 0;
    left: 0;
    border-width: 2px 0 0 2px;
  }

  .contact__qr-corner[data-pos='tr'] {
    top: 0;
    right: 0;
    border-width: 2px 2px 0 0;
  }

  .contact__qr-corner[data-pos='bl'] {
    bottom: 0;
    left: 0;
    border-width: 0 0 2px 2px;
  }

  .contact__qr-corner[data-pos='br'] {
    bottom: 0;
    right: 0;
    border-width: 0 2px 2px 0;
  }

  .contact__qr-pad {
    display: block;
    padding: 0.35rem;
    background: var(--color-ink);
  }

  .contact__qr-img {
    display: block;
    width: 11.25rem;
    height: 11.25rem;
    /* Nearest-neighbor when scaled so QR modules stay sharp */
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    image-rendering: pixelated;
  }
</style>

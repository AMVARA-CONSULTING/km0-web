---
import type { TocEntry } from '../lib/reading';
import { formatReadingTime } from '../lib/reading';

interface NavLink {
  href: string;
  title: string;
}

interface RelatedLink {
  href: string;
  title: string;
  description: string;
}

interface Props {
  breadcrumbHome: string;
  breadcrumbHomeHref: string;
  title: string;
  description: string;
  readingTimeLabel: string;
  readingMinutes: number;
  tocTitle: string;
  toc: TocEntry[];
  prevLabel: string;
  nextLabel: string;
  backHref: string;
  backLabel: string;
  relatedTitle?: string;
  pubDate?: Date;
  pubDateLabel?: string;
  platformLabel?: string;
  prev?: NavLink;
  next?: NavLink;
  related?: RelatedLink[];
}

const {
  breadcrumbHome,
  breadcrumbHomeHref,
  title,
  description,
  readingTimeLabel,
  readingMinutes,
  tocTitle,
  toc,
  prevLabel,
  nextLabel,
  backHref,
  backLabel,
  relatedTitle,
  pubDate,
  pubDateLabel,
  platformLabel,
  prev,
  next,
  related = [],
} = Astro.props;

const hasToc = toc.length >= 3;
const readingTime = formatReadingTime(readingTimeLabel, readingMinutes);
---

<article class="reading-shell" data-reading>
  <nav class="reading-crumb" aria-label="Breadcrumb">
    <a href={breadcrumbHomeHref} class="reading-crumb-link">{breadcrumbHome}</a>
    <span class="reading-crumb-sep" aria-hidden="true">/</span>
    <span class="reading-crumb-current">{title}</span>
  </nav>

  {
    hasToc && (
      <details class="reading-toc-mobile">
        <summary class="reading-toc-mobile-summary">
          <span>{tocTitle}</span>
          <svg
            class="reading-toc-mobile-chevron"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <nav class="reading-toc" aria-label={tocTitle} data-reading-toc>
          <ol class="reading-toc-list">
            {toc.map((entry) => (
              <li class:list={['reading-toc-item', entry.level === 3 && 'reading-toc-item--nested']}>
                <a href={`#${entry.id}`} class="reading-toc-link" data-toc-link>
                  {entry.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </details>
    )
  }

  <div class:list={['reading-layout', hasToc && 'reading-layout--toc']}>
    <div class="reading-column">
      <header class="reading-lede">
        <div class="reading-meta">
          {platformLabel && <span class="reading-platform">{platformLabel}</span>}
          {pubDate && pubDateLabel && (
            <time datetime={pubDate.toISOString()}>{pubDateLabel}</time>
          )}
          <span>{readingTime}</span>
        </div>
        <h1 class="reading-title">{title}</h1>
        <p class="reading-dek">{description}</p>
      </header>

      <div class="reading-prose">
        <slot />
      </div>

      {
        (prev || next) && (
          <nav class="reading-pager" aria-label="Article navigation">
            {prev ? (
              <a href={prev.href} class="reading-pager-link reading-pager-link--prev">
                <span class="reading-pager-label">{prevLabel}</span>
                <span class="reading-pager-title">{prev.title}</span>
              </a>
            ) : (
              <span class="reading-pager-spacer" aria-hidden="true" />
            )}
            {next ? (
              <a href={next.href} class="reading-pager-link reading-pager-link--next">
                <span class="reading-pager-label">{nextLabel}</span>
                <span class="reading-pager-title">{next.title}</span>
              </a>
            ) : (
              <span class="reading-pager-spacer" aria-hidden="true" />
            )}
          </nav>
        )
      }

      {
        related.length > 0 && relatedTitle && (
          <section class="reading-more" aria-labelledby="reading-more-heading">
            <h2 id="reading-more-heading" class="reading-more-heading">
              {relatedTitle}
            </h2>
            <ul class="reading-more-list">
              {related.map((item) => (
                <li>
                  <a href={item.href} class="reading-more-link">
                    <span class="reading-more-link-title">{item.title}</span>
                    <span class="reading-more-link-desc">{item.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <footer class="reading-foot">
        <a href={backHref} class="reading-back">{backLabel}</a>
      </footer>
    </div>

    {
      hasToc && (
        <aside class="reading-toc-rail" aria-label={tocTitle}>
          <nav class="reading-toc reading-toc--sticky" data-reading-toc>
            <p class="reading-toc-label">{tocTitle}</p>
            <ol class="reading-toc-list">
              {toc.map((entry) => (
                <li class:list={['reading-toc-item', entry.level === 3 && 'reading-toc-item--nested']}>
                  <a href={`#${entry.id}`} class="reading-toc-link" data-toc-link>
                    {entry.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )
    }
  </div>
</article>

<script>
  import '../scripts/doc-reading.ts';
</script>

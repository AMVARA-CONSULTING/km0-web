---
import type { Messages } from '../i18n/types';

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;
---

<section id="faq" class="section-pad faq" aria-labelledby="faq-heading">
  <div class="mx-auto max-w-3xl">
    <header class="faq__header" data-reveal>
      <h2 id="faq-heading" class="heading-section text-navy">
        {m.faq.heading}
      </h2>
    </header>

    <div class="faq__list" data-faq-accordion>
      {
        m.faq.items.map((item, i) => (
          <div
            data-faq-item
            data-reveal
            data-delay={String(80 + i * 60)}
            class="faq-item"
            data-open={i === 0 ? 'true' : 'false'}
          >
            <button
              type="button"
              class="faq-trigger"
              aria-expanded={i === 0 ? 'true' : 'false'}
            >
              <span>{item.question}</span>
              <svg
                class="faq-chevron h-5 w-5 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-panel" data-faq-panel>
              <div
                class="faq-panel__content [&_a]:font-medium [&_a]:text-signal [&_a]:underline [&_a]:underline-offset-2"
                set:html={item.answerHtml}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import '../scripts/faq-accordion.ts';
</script>

<style>
  .faq__header {
    margin-bottom: 2rem;
  }

  .faq__list {
    border-top: 1px solid var(--color-mist);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-mist);
  }

  .faq-trigger {
    display: flex;
    width: 100%;
    cursor: pointer;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 0;
    text-align: left;
    font-family: theme('fontFamily.display');
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-ink);
    background: transparent;
    border: 0;
  }

  .faq-trigger:hover {
    color: var(--color-signal);
  }

  .faq-trigger:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 4px;
  }

  .faq-chevron {
    color: color-mix(in srgb, var(--color-ink) 40%, transparent);
    transition: transform 0.3s var(--ease-out-expo);
  }

  .faq-panel {
    height: 0;
    overflow: hidden;
    transition: height 0.35s var(--ease-out-expo);
  }

  .faq-panel__content {
    padding: 0 0 1.25rem;
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }

  .faq-item[data-open='true'] .faq-chevron {
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-panel,
    .faq-chevron {
      transition: none;
    }
  }
</style>

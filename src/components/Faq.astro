---
import type { Messages } from '../i18n/types';

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;
---

<section id="faq" class="section-pad bg-surface">
  <div class="mx-auto max-w-3xl">
    <p data-reveal class="mb-4 text-center text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.faq.eyebrow}
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-12 text-center text-navy">
      {m.faq.heading}
    </h2>

    <div class="rounded-2xl border border-navy/10 bg-white shadow-sm" data-faq-accordion>
      {
        m.faq.items.map((item, i) => (
          <div
            data-faq-item
            data-reveal
            data-delay={String(160 + i * 80)}
            class="faq-item border-b border-navy/10 last:border-b-0"
            data-open={i === 0 ? 'true' : 'false'}
          >
            <button
              type="button"
              class="faq-trigger flex w-full cursor-pointer items-center justify-between gap-4 px-6 py-5 text-left text-lg font-semibold text-navy transition-colors hover:text-navy/80"
              aria-expanded={i === 0 ? 'true' : 'false'}
            >
              <span>{item.question}</span>
              <svg
                class="faq-chevron h-5 w-5 shrink-0 text-navy/40 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-panel" data-faq-panel>
              <div
                class="faq-panel__content px-6 pb-5 text-base leading-relaxed text-navy/70 [&_a]:font-medium [&_a]:text-navy [&_a]:underline [&_a]:decoration-navy/30 [&_a]:underline-offset-2 [&_a]:transition-colors hover:[&_a]:decoration-navy"
                set:html={item.answerHtml}
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import '../scripts/faq-accordion.ts';
</script>

<style>
  .faq-panel {
    height: 0;
    overflow: hidden;
    transition: height 0.35s var(--ease-apple);
  }

  .faq-item[data-open='true'] .faq-chevron {
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-panel,
    .faq-chevron {
      transition: none;
    }
  }
</style>

---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { withHash, localeHref } from '../i18n/paths';
import { SITE_VERSION } from '../lib/site-version';

interface Props {
  locale: Locale;
  messages: Messages;
}

const year = new Date().getFullYear();
const { locale, messages: m } = Astro.props;
---

<footer class="border-t border-navy/10 bg-surface px-6 py-12 md:px-12">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 md:flex-row"
  >
    <div class="flex items-center gap-3">
      <img
        src="/brand/logo.png"
        alt=""
        width="40"
        height="40"
        class="h-10 w-10 object-contain"
      />
      <span class="text-sm font-medium text-navy/80">
        {m.brandName}
      </span>
    </div>
    <div class="flex flex-col items-center gap-1 text-center md:items-start">
      <p class="text-sm text-navy/50">
        © {year} {m.brandName}. {m.footer.rights}
      </p>
      <p
        class="text-xs font-medium tabular-nums tracking-wide text-navy/45"
        title={`${m.footer.version} ${SITE_VERSION}`}
      >
        {m.footer.version}
        <span class="text-navy/60">{SITE_VERSION}</span>
      </p>
    </div>
    <nav class="flex flex-wrap justify-center gap-6 text-sm text-navy/50">
      <a href={withHash(locale, 'home')} class="transition-colors hover:text-navy">{m.nav.home}</a>
      <a href={withHash(locale, 'mission')} class="transition-colors hover:text-navy">{m.nav.mission}</a>
      <a href={localeHref(locale, '/doc/')} class="transition-colors hover:text-navy">{m.nav.blog}</a>
      <a href={withHash(locale, 'contact')} class="transition-colors hover:text-navy">{m.nav.contact}</a>
      <a
        href="https://github.com/AMVARA-CONSULTING/km0-web"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-navy"
      >{m.footer.github}</a>
    </nav>
  </div>
</footer>

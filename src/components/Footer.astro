---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { formatDocDate } from '../lib/doc';
import { REPO_CREATED_AT, REPO_URL } from '../lib/repo-created-at';
import { SITE_VERSION } from '../lib/site-version';
import { footerNavColumns } from '../lib/site-nav';

interface Props {
  locale: Locale;
  messages: Messages;
}

const year = new Date().getFullYear();
const { locale, messages: m } = Astro.props;
const footerColumns = footerNavColumns(locale, m);
---

<footer class="site-footer surface-paper border-t-2 border-signal px-6 py-14 md:px-12">
  <div class="mx-auto max-w-6xl">
    <nav aria-label={m.footer.navAriaLabel}>
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-2 md:grid-cols-4">
        {
          footerColumns.map((column) => (
            <div>
              <h3 class="mb-3 font-sans text-xs font-semibold uppercase tracking-[0.12em] text-ink/50">
                {column.title}
              </h3>
              <ul class="flex flex-col gap-2">
                {
                  column.links.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="font-sans text-sm text-ink/60 transition-colors hover:text-signal"
                        {...(link.external
                          ? { target: '_blank', rel: 'noopener noreferrer' }
                          : {})}
                      >
                        {link.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          ))
        }
      </div>
    </nav>
  </div>

  <div
    class="mx-auto mt-12 grid max-w-6xl grid-cols-1 items-center gap-6 border-t border-mist pt-8 md:grid-cols-3"
  >
    <div class="flex items-center justify-center gap-3 md:justify-start">
      <img
        src="/brand/logo.svg"
        alt=""
        width="40"
        height="40"
        class="h-10 w-10 object-contain"
      />
      <span class="font-display text-sm font-semibold tracking-tight text-ink">
        {m.brandName}
      </span>
    </div>
    <div class="flex flex-col items-center gap-1 text-center">
      <p class="font-sans text-sm text-ink/50">
        © {year} {m.brandName}. {m.footer.rights}
      </p>
      <p
        class="font-sans text-xs font-medium tabular-nums tracking-wide text-ink/45"
        title={`${m.footer.version} ${SITE_VERSION}`}
      >
        {m.footer.version}
        <span class="text-ink/60">{SITE_VERSION}</span>
      </p>
      <p class="font-sans text-xs text-ink/45">
        {m.footer.repoSince}{' '}
        <a
          href={REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-ink/60 underline decoration-signal/30 underline-offset-2 transition-colors hover:text-signal"
          title={REPO_URL}
        >{formatDocDate(REPO_CREATED_AT, locale)}</a>
      </p>
      <p
        class="font-sans text-sm text-ink/50 [&_a]:font-semibold [&_a]:text-ink/70 [&_a]:underline [&_a]:decoration-signal/30 [&_a]:underline-offset-2 [&_a]:transition-colors hover:[&_a]:text-signal"
        set:html={m.footer.poweredByHtml}
      />
    </div>
    <div class="flex items-center justify-center md:justify-end">
      <a
        href="https://github.com/AMVARA-CONSULTING/km0-web"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 font-sans text-sm text-ink/50 transition-colors hover:text-signal"
      >
        <svg
          class="h-4 w-4 shrink-0"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        {m.footer.github}
      </a>
    </div>
  </div>
</footer>

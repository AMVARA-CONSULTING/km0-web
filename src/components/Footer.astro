---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { formatDocDate } from '../lib/doc';
import { REPO_CREATED_AT, REPO_URL } from '../lib/repo-created-at';
import { SITE_VERSION } from '../lib/site-version';

interface Props {
  locale: Locale;
  messages: Messages;
}

const year = new Date().getFullYear();
const { locale, messages: m } = Astro.props;
---

<footer class="border-t border-navy/10 bg-surface px-6 py-12 md:px-12">
  <div
    class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-6 md:grid-cols-3"
  >
    <div class="flex items-center justify-center gap-3 md:justify-start">
      <img
        src="/brand/logo.png"
        alt=""
        width="40"
        height="40"
        class="h-10 w-10 object-contain"
      />
      <span class="text-sm font-medium text-navy/80">
        {m.brandName}
      </span>
    </div>
    <div class="flex flex-col items-center gap-1 text-center">
      <p class="text-sm text-navy/50">
        © {year} {m.brandName}. {m.footer.rights}
      </p>
      <p
        class="text-xs font-medium tabular-nums tracking-wide text-navy/45"
        title={`${m.footer.version} ${SITE_VERSION}`}
      >
        {m.footer.version}
        <span class="text-navy/60">{SITE_VERSION}</span>
      </p>
      <p class="text-xs text-navy/45">
        {m.footer.repoSince}{' '}
        <a
          href={REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-navy/60 underline decoration-navy/20 underline-offset-2 transition-colors hover:text-navy hover:decoration-navy/50"
          title={REPO_URL}
        >{formatDocDate(REPO_CREATED_AT, locale)}</a>
      </p>
      <p
        class="text-sm text-navy/50 [&_a]:font-semibold [&_a]:text-navy/70 [&_a]:underline [&_a]:decoration-navy/20 [&_a]:underline-offset-2 [&_a]:transition-colors hover:[&_a]:text-navy hover:[&_a]:decoration-navy/50"
        set:html={m.footer.poweredByHtml}
      />
    </div>
    <nav class="flex justify-center md:justify-end">
      <a
        href="https://github.com/AMVARA-CONSULTING/km0-web"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm text-navy/50 transition-colors hover:text-navy"
      >
        <svg
          class="h-4 w-4 shrink-0"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        {m.footer.github}
      </a>
    </nav>
  </div>
</footer>

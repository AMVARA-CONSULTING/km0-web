---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { withHash, localeHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const year = new Date().getFullYear();
const { locale, messages: m } = Astro.props;
---

<footer class="border-t border-navy/10 bg-surface px-6 py-12 md:px-12">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 md:flex-row"
  >
    <div class="flex items-center gap-3">
      <img
        src="/brand/logo.png"
        alt=""
        width="40"
        height="40"
        class="h-10 w-10 object-contain"
      />
      <span class="text-sm font-medium text-navy/80">
        {m.brandName}
      </span>
    </div>
    <p class="text-sm text-navy/50">
      © {year} {m.brandName}. {m.footer.rights}
    </p>
    <nav class="flex gap-6 text-sm text-navy/50">
      <a href={withHash(locale, 'inicio')} class="transition-colors hover:text-navy">{m.nav.inicio}</a>
      <a href={withHash(locale, 'mision')} class="transition-colors hover:text-navy">{m.nav.mision}</a>
      <a href={localeHref(locale, '/doc/')} class="transition-colors hover:text-navy">{m.nav.blog}</a>
      <a href={withHash(locale, 'contacto')} class="transition-colors hover:text-navy">{m.nav.contacto}</a>
    </nav>
  </div>
</footer>

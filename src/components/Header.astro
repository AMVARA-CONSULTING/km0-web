---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeBcp47 } from '../i18n/types';
import { withHash, switchLocaleHref } from '../i18n/paths';
import { headerNavLinks } from '../lib/site-nav';
import ServicesLauncher from './ServicesLauncher.astro';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const pathname = Astro.url.pathname;

const nav = headerNavLinks(locale, m);

const langs: { code: Locale; href: string; label: string }[] = [
  { code: 'ca', href: switchLocaleHref(pathname, locale, 'ca'), label: 'CA' },
  { code: 'de', href: switchLocaleHref(pathname, locale, 'de'), label: 'DE' },
  { code: 'en', href: switchLocaleHref(pathname, locale, 'en'), label: 'EN' },
  { code: 'es', href: switchLocaleHref(pathname, locale, 'es'), label: 'ES' },
];
---

<header class="masthead" data-mobile-nav-root>
  <nav class="masthead__bar" aria-label="Primary">
    <a href={withHash(locale, 'home')} class="masthead__brand">
      <img
        src="/brand/logo.svg"
        alt={m.hero.logoAlt}
        width="36"
        height="36"
        class="masthead__logo"
      />
      <span class="masthead__wordmark">
        {m.brandMark.before}<span class="masthead__zero">0</span>{m.brandMark.after}
      </span>
    </a>

    <div class="masthead__end">
      <ul class="masthead__links">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class="masthead__link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="masthead__langs" role="navigation" aria-label="Language">
        {
          langs.map((lang, i) => (
            <span class="masthead__lang-item">
              {i > 0 && <span class="masthead__lang-sep" aria-hidden="true">/</span>}
              <a
                href={lang.href}
                data-lang-switch
                class:list={[
                  'masthead__lang',
                  locale === lang.code && 'masthead__lang--active',
                ]}
                hreflang={localeBcp47[lang.code]}
              >
                {lang.label}
              </a>
            </span>
          ))
        }
      </div>

      <ServicesLauncher messages={m} />

      <button
        type="button"
        class="masthead__menu-btn"
        data-mobile-menu-toggle
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label={m.nav.menuOpen}
        data-label-open={m.nav.menuOpen}
        data-label-close={m.nav.menuClose}
      >
        <svg
          class="h-5 w-5"
          data-menu-icon-open
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        <svg
          class="hidden h-5 w-5"
          data-menu-icon-close
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-nav"
    class="masthead__mobile"
    hidden
    data-open="false"
  >
    <ul class="masthead__mobile-list">
      {
        nav.map((item) => (
          <li>
            <a href={item.href} data-mobile-nav-link class="masthead__mobile-link">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  function applyLangSwitchHash() {
    const hash = window.location.hash;
    if (!hash) return;
    document.querySelectorAll<HTMLAnchorElement>('[data-lang-switch]').forEach((link) => {
      link.href = `${link.pathname}${hash}`;
    });
  }

  function initMobileMenu() {
    const root = document.querySelector('[data-mobile-nav-root]');
    const toggle = root?.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
    const menu = document.getElementById('mobile-nav');
    const iconOpen = toggle?.querySelector('[data-menu-icon-open]');
    const iconClose = toggle?.querySelector('[data-menu-icon-close]');
    if (!toggle || !menu || !iconOpen || !iconClose) return;

    const openLabel = toggle.dataset.labelOpen ?? '';
    const closeLabel = toggle.dataset.labelClose ?? '';

    const setOpen = (open: boolean) => {
      menu.hidden = !open;
      menu.dataset.open = open ? 'true' : 'false';
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? closeLabel : openLabel);
      iconOpen.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
      document.body.classList.toggle('overflow-hidden', open);
    };

    toggle.addEventListener('click', () => setOpen(menu.hidden));
    menu.querySelectorAll('[data-mobile-nav-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !menu.hidden) setOpen(false);
    });
  }

  applyLangSwitchHash();
  window.addEventListener('hashchange', applyLangSwitchHash);
  initMobileMenu();
</script>

<style>
  .masthead {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    background: var(--color-snow);
    border-bottom: 1px solid transparent;
    box-shadow: none;
    transition:
      border-color var(--duration-chrome) var(--ease-out-expo),
      box-shadow var(--duration-chrome) var(--ease-out-expo);
  }

  /* Compact within ~1 scroll: shorter bar, smaller mark, Mist hairline + soft lift */
  .masthead--compact {
    border-bottom-color: var(--color-mist);
    box-shadow: var(--masthead-elevate);
  }

  .masthead__bar {
    margin: 0 auto;
    display: flex;
    max-width: 72rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.5rem;
    transition: padding var(--duration-chrome) var(--ease-out-expo);
  }

  .masthead--compact .masthead__bar {
    padding-block: 0.45rem;
  }

  @media (min-width: 768px) {
    .masthead__bar {
      padding-inline: 3rem;
    }
  }

  .masthead__brand {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-ink);
    text-decoration: none;
  }

  .masthead__logo {
    height: 2.35rem;
    width: 2.35rem;
    flex-shrink: 0;
    object-fit: contain;
    transition:
      width var(--duration-chrome) var(--ease-out-expo),
      height var(--duration-chrome) var(--ease-out-expo);
  }

  .masthead--compact .masthead__logo {
    height: 1.6rem;
    width: 1.6rem;
  }

  .masthead__wordmark {
    display: none;
    font-family: theme('fontFamily.display');
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    transition: font-size var(--duration-chrome) var(--ease-out-expo);
  }

  .masthead--compact .masthead__wordmark {
    font-size: 0.9rem;
  }

  @media (min-width: 640px) {
    .masthead__wordmark {
      display: inline;
    }
  }

  .masthead__zero {
    color: var(--color-signal);
  }

  .masthead__end {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .masthead__end {
      gap: 1.25rem;
    }
  }

  .masthead__links {
    display: none;
    margin: 0;
    padding: 0;
    list-style: none;
    gap: 1.15rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 500;
  }

  @media (min-width: 900px) {
    .masthead__links {
      display: flex;
    }
  }

  .masthead__link {
    color: color-mix(in srgb, var(--color-ink) 72%, transparent);
    text-decoration: none;
    transition: color 0.25s var(--ease-out-expo);
  }

  .masthead__link:hover {
    color: var(--color-ink);
  }

  .masthead__link:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 3px;
  }

  .masthead__langs {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .masthead__lang-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .masthead__lang {
    color: color-mix(in srgb, var(--color-ink) 45%, transparent);
    text-decoration: none;
    transition: color 0.2s var(--ease-out-expo);
  }

  .masthead__lang:hover,
  .masthead__lang--active {
    color: var(--color-ink);
  }

  .masthead__lang--active {
    text-decoration: underline;
    text-decoration-color: var(--color-signal);
    text-underline-offset: 0.2em;
  }

  .masthead__lang-sep {
    color: var(--color-mist);
  }

  .masthead__menu-btn {
    display: inline-flex;
    height: 2.5rem;
    width: 2.5rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-mist);
    background: var(--color-snow);
    color: var(--color-ink);
    border-radius: 0.375rem;
  }

  @media (min-width: 900px) {
    .masthead__menu-btn {
      display: none;
    }
  }

  .masthead__menu-btn:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 2px;
  }

  .masthead__mobile {
    display: block;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    border-bottom: 1px solid var(--color-mist);
    background: var(--color-snow);
    transition:
      max-height 0.35s var(--ease-out-expo),
      opacity 0.25s var(--ease-out-expo);
  }

  @media (min-width: 900px) {
    .masthead__mobile {
      display: none;
    }
  }

  .masthead__mobile[data-open='true'] {
    max-height: calc(100dvh - 4.75rem);
    overflow-y: auto;
    opacity: 1;
    -webkit-overflow-scrolling: touch;
  }

  .masthead__mobile-list {
    margin: 0 auto;
    display: flex;
    max-width: 72rem;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.75rem 1.5rem 1.25rem;
    list-style: none;
    font-family: theme('fontFamily.sans');
    font-size: 1rem;
    font-weight: 500;
  }

  .masthead__mobile-link {
    display: block;
    padding: 0.75rem 0.5rem;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-mist);
  }

  @media (prefers-reduced-motion: reduce) {
    .masthead,
    .masthead__bar,
    .masthead__logo,
    .masthead__wordmark,
    .masthead__mobile {
      transition: none;
    }
  }
</style>

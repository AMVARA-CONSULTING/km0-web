---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeBcp47 } from '../i18n/types';
import { withHash, localeHref, switchLocaleHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const pathname = Astro.url.pathname;

const nav = [
  { id: 'services', label: m.nav.services, href: withHash(locale, 'services') },
  { id: 'tutorials', label: m.nav.tutorials, href: localeHref(locale, '/tutorials/') },
  { id: 'presentation', label: m.nav.presentation, href: localeHref(locale, '/presentation/') },
  { id: 'pricing', label: m.nav.pricing, href: localeHref(locale, '/pricing/') },
  { id: 'blog', label: m.nav.blog, href: localeHref(locale, '/doc/') },
  { id: 'ideas', label: m.nav.ideas, href: localeHref(locale, '/ideas/') },
  { id: 'contact', label: m.nav.contact, href: withHash(locale, 'contact') },
] as const;

const langs: { code: Locale; href: string; label: string }[] = [
  { code: 'ca', href: switchLocaleHref(pathname, locale, 'ca'), label: 'CA' },
  { code: 'de', href: switchLocaleHref(pathname, locale, 'de'), label: 'DE' },
  { code: 'en', href: switchLocaleHref(pathname, locale, 'en'), label: 'EN' },
  { code: 'es', href: switchLocaleHref(pathname, locale, 'es'), label: 'ES' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-navy/80 backdrop-blur-md"
  data-mobile-nav-root
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4 md:px-12"
  >
    <a href={withHash(locale, 'home')} class="flex min-w-0 items-center gap-3 text-white">
      <img
        src="/brand/logo.svg"
        alt={m.hero.logoAlt}
        width="44"
        height="44"
        class="h-10 w-10 shrink-0 object-contain sm:h-11 sm:w-11"
      />
      <span class="hidden text-sm font-semibold tracking-wide sm:inline">
        {m.brandMark.before}<span class="text-gradient font-bold">0</span>{m.brandMark.after}
      </span>
    </a>
    <div class="flex items-center gap-3 md:gap-6">
      <ul class="hidden gap-5 text-sm text-white/70 md:flex">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="transition-colors duration-300 hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div
        class="flex shrink-0 items-center gap-1 rounded-full border border-white/15 bg-white/5 px-1 py-0.5 text-xs font-medium text-white/80"
        role="navigation"
        aria-label="Language"
      >
        {
          langs.map((lang) => (
            <a
              href={lang.href}
              data-lang-switch
              class:list={[
                'rounded-full px-2 py-1 transition-colors',
                locale === lang.code
                  ? 'bg-white/15 text-white'
                  : 'text-white/60 hover:text-white',
              ]}
              hreflang={localeBcp47[lang.code]}
            >
              {lang.label}
            </a>
          ))
        }
      </div>
      <button
        type="button"
        class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/5 text-white transition-colors hover:bg-white/10 md:hidden"
        data-mobile-menu-toggle
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label={m.nav.menuOpen}
        data-label-open={m.nav.menuOpen}
        data-label-close={m.nav.menuClose}
      >
        <svg
          class="h-5 w-5"
          data-menu-icon-open
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        <svg
          class="hidden h-5 w-5"
          data-menu-icon-close
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </nav>
  <div
    id="mobile-nav"
    class="mobile-nav border-b border-white/10 bg-navy/95 backdrop-blur-md md:hidden"
    hidden
    data-open="false"
  >
    <ul class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-4 text-base font-medium text-white/80">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              data-mobile-nav-link
              class="block rounded-lg px-3 py-3 transition-colors hover:bg-white/5 hover:text-white"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  function applyLangSwitchHash() {
    const hash = window.location.hash;
    if (!hash) return;
    document.querySelectorAll<HTMLAnchorElement>('[data-lang-switch]').forEach((link) => {
      link.href = `${link.pathname}${hash}`;
    });
  }

  function initMobileMenu() {
    const root = document.querySelector('[data-mobile-nav-root]');
    const toggle = root?.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
    const menu = document.getElementById('mobile-nav');
    const iconOpen = toggle?.querySelector('[data-menu-icon-open]');
    const iconClose = toggle?.querySelector('[data-menu-icon-close]');
    if (!toggle || !menu || !iconOpen || !iconClose) return;

    const openLabel = toggle.dataset.labelOpen ?? '';
    const closeLabel = toggle.dataset.labelClose ?? '';

    const setOpen = (open: boolean) => {
      menu.hidden = !open;
      menu.dataset.open = open ? 'true' : 'false';
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? closeLabel : openLabel);
      iconOpen.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
      document.body.classList.toggle('overflow-hidden', open);
    };

    toggle.addEventListener('click', () => setOpen(menu.hidden));
    menu.querySelectorAll('[data-mobile-nav-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !menu.hidden) setOpen(false);
    });
  }

  applyLangSwitchHash();
  window.addEventListener('hashchange', applyLangSwitchHash);
  initMobileMenu();
</script>

<style>
  .mobile-nav {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
      opacity 0.25s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .mobile-nav[data-open='true'] {
    max-height: calc(100dvh - 4.75rem);
    overflow-y: auto;
    opacity: 1;
    -webkit-overflow-scrolling: touch;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-nav {
      transition: none;
    }
  }
</style>

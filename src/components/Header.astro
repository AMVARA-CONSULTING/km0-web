---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { withHash, localeHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;

const nav = [
  { id: 'inicio', label: m.nav.inicio, href: withHash(locale, 'inicio') },
  { id: 'valores', label: m.nav.valores, href: withHash(locale, 'valores') },
  { id: 'servicios', label: m.nav.servicios, href: withHash(locale, 'servicios') },
  { id: 'significado', label: m.nav.significado, href: withHash(locale, 'significado') },
  { id: 'mision', label: m.nav.mision, href: withHash(locale, 'mision') },
  { id: 'blog', label: m.nav.blog, href: localeHref(locale, '/doc/') },
  { id: 'contacto', label: m.nav.contacto, href: withHash(locale, 'contacto') },
] as const;

const langs: { code: Locale; href: string; label: string }[] = [
  { code: 'ca', href: '/ca/', label: 'CA' },
  { code: 'es', href: '/', label: 'ES' },
  { code: 'en', href: '/en/', label: 'EN' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-navy/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4 md:px-12"
  >
    <a href={withHash(locale, 'inicio')} class="flex min-w-0 items-center gap-3 text-white">
      <img
        src="/brand/logo.png"
        alt={m.hero.logoAlt}
        width="44"
        height="44"
        class="h-10 w-10 shrink-0 object-contain sm:h-11 sm:w-11"
      />
      <span class="hidden text-sm font-semibold tracking-wide sm:inline">
        {m.brandMark.before}<span class="text-gradient font-bold">0</span>{m.brandMark.after}
      </span>
    </a>
    <div class="flex items-center gap-4 md:gap-6">
      <ul class="hidden gap-5 text-sm text-white/70 md:flex">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="transition-colors duration-300 hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div
        class="flex shrink-0 items-center gap-1 rounded-full border border-white/15 bg-white/5 px-1 py-0.5 text-xs font-medium text-white/80"
        role="navigation"
        aria-label="Language"
      >
        {
          langs.map((lang) => (
            <a
              href={lang.href}
              class:list={[
                'rounded-full px-2 py-1 transition-colors',
                locale === lang.code
                  ? 'bg-white/15 text-white'
                  : 'text-white/60 hover:text-white',
              ]}
              hreflang={
                lang.code === 'es' ? 'es' : lang.code === 'ca' ? 'ca' : 'en'
              }
            >
              {lang.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const cloudItem = m.services.items.find((item) => item.id === 'cloud');
const emailItem = m.services.items.find((item) => item.id === 'email');
const cloudHref = cloudItem?.url ?? 'https://cloud.km0digital.com';
const proof = m.hero.proof;
---

<section id="home" class="hero km0-motif km0-motif--origin" aria-labelledby="hero-heading">
  <div class="hero__grid">
    <div class="hero__copy" data-reveal>
      <p class="hero__brand">
        {m.brandMark.before}<span class="hero__brand-zero">0</span>{m.brandMark.after}
      </p>
      <h1 id="hero-heading" class="hero__headline">
        {m.hero.titleLine1}<span class="hero__headline-accent">{m.hero.titleGradient}</span>
      </h1>
      <p class="hero__support">{m.hero.tagline}</p>
      <div class="hero__cta">
        <a href={cloudHref} class="btn-primary">{m.hero.ctaPrimary}</a>
        <a href={localeHref(locale, '/pricing/')} class="hero__link">
          {m.hero.ctaSecondary}
        </a>
      </div>
    </div>

    <div class="hero__visual" data-reveal data-delay="120" aria-hidden="true">
      <div class="hero__proof">
        <div class="hero__proof-chrome">
          <img
            src="/brand/logo.svg"
            alt=""
            width="28"
            height="28"
            class="hero__proof-stamp"
          />
          <span class="hero__proof-app">{cloudItem?.title ?? 'KM0 Cloud'}</span>
          <span class="hero__proof-status">{proof.status}</span>
        </div>

        <div class="hero__proof-plan">
          <div class="hero__proof-plan-row">
            <span class="hero__proof-plan-name">{proof.planName}</span>
            {
              cloudItem?.priceFrom && (
                <span class="hero__proof-plan-price">{cloudItem.priceFrom}</span>
              )
            }
          </div>
          <div class="hero__proof-meter">
            <span class="hero__proof-meter-fill"></span>
          </div>
          <p class="hero__proof-plan-meta">{proof.planMeta}</p>
        </div>

        <ul class="hero__proof-files">
          {
            proof.files.map((file) => (
              <li class="hero__proof-file">
                <span class="hero__proof-file-icon" data-kind={file.kind}></span>
                <span class="hero__proof-file-name">{file.name}</span>
                <span class="hero__proof-file-meta">{file.meta}</span>
              </li>
            ))
          }
        </ul>

        {
          emailItem && (
            <div class="hero__proof-email">
              <span class="hero__proof-email-label">{emailItem.title}</span>
              <span class="hero__proof-email-meta">{proof.emailMeta}</span>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    color: var(--color-ink);
    padding: 7.5rem 1.5rem 4rem;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 8.5rem 3rem 5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 9rem 5rem 6rem;
      min-height: min(100svh, 52rem);
      display: flex;
      align-items: center;
    }
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    margin: 0 auto;
    display: grid;
    gap: 3rem;
    width: 100%;
    max-width: 72rem;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero__grid {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: 4rem;
    }
  }

  .hero__brand {
    margin: 0 0 1.25rem;
    font-family: theme('fontFamily.display');
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-ink);
  }

  .hero__brand-zero {
    color: var(--color-signal);
  }

  .hero__headline {
    margin: 0 0 1.25rem;
    max-width: 18ch;
    font-family: theme('fontFamily.display');
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .hero__headline-accent {
    color: var(--color-signal);
  }

  .hero__support {
    margin: 0;
    max-width: 34rem;
    font-family: theme('fontFamily.body');
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.55;
    color: var(--color-ink-muted);
  }

  .hero__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .hero__link {
    font-family: theme('fontFamily.sans');
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: rgb(15 118 110 / 0.45);
    text-underline-offset: 0.2em;
    transition: color 0.3s var(--ease-out-expo), text-decoration-color 0.3s var(--ease-out-expo);
  }

  .hero__link:hover {
    color: var(--color-signal);
    text-decoration-color: var(--color-signal);
  }

  .hero__link:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 4px;
  }

  .hero__visual {
    justify-self: stretch;
    max-width: 28rem;
    margin-inline: auto;
  }

  @media (min-width: 960px) {
    .hero__visual {
      max-width: none;
      margin-inline: 0;
      justify-self: end;
      width: 100%;
    }
  }

  /* Product UI crop (not a marketing card shrine) */
  .hero__proof {
    position: relative;
    display: grid;
    gap: 0;
    background: var(--color-snow);
    border: 1px solid var(--color-mist);
    border-left: 3px solid var(--color-signal);
    box-shadow: 6px 6px 0 rgb(11 18 32 / 0.05);
    overflow: hidden;
  }

  .hero__proof-chrome {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.7rem 0.9rem;
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-mist);
  }

  .hero__proof-stamp {
    width: 1.5rem;
    height: 1.5rem;
    display: block;
    flex-shrink: 0;
    border-radius: 0.2rem;
  }

  .hero__proof-app {
    flex: 1;
    min-width: 0;
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .hero__proof-status {
    font-family: theme('fontFamily.sans');
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-signal);
    white-space: nowrap;
  }

  .hero__proof-plan {
    padding: 1rem 0.95rem 0.85rem;
    border-bottom: 1px solid var(--color-mist);
  }

  .hero__proof-plan-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    margin-bottom: 0.65rem;
  }

  .hero__proof-plan-name {
    font-family: theme('fontFamily.display');
    font-size: 1.05rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .hero__proof-plan-price {
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-signal);
  }

  .hero__proof-meter {
    height: 0.35rem;
    background: var(--color-mist);
    overflow: hidden;
  }

  .hero__proof-meter-fill {
    display: block;
    height: 100%;
    width: 28%;
    background: var(--color-signal);
    transform-origin: left center;
    animation: hero-meter 0.9s var(--ease-out-expo) 0.35s both;
  }

  .hero__proof-plan-meta {
    margin: 0.55rem 0 0;
    font-family: theme('fontFamily.sans');
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .hero__proof-files {
    margin: 0;
    padding: 0.35rem 0;
    list-style: none;
  }

  .hero__proof-file {
    display: grid;
    grid-template-columns: 1.1rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.95rem;
    font-family: theme('fontFamily.sans');
    border-bottom: 1px solid rgb(216 220 224 / 0.55);
  }

  .hero__proof-file:last-child {
    border-bottom: none;
  }

  .hero__proof-file-icon {
    width: 0.85rem;
    height: 0.7rem;
    border: 1.5px solid var(--color-ink-muted);
    border-radius: 0.1rem 0.1rem 0.05rem 0.05rem;
    position: relative;
    opacity: 0.7;
  }

  .hero__proof-file-icon::before {
    content: '';
    position: absolute;
    top: -0.28rem;
    left: 0;
    width: 0.4rem;
    height: 0.22rem;
    border: 1.5px solid var(--color-ink-muted);
    border-bottom: none;
    border-radius: 0.08rem 0.08rem 0 0;
  }

  .hero__proof-file-icon[data-kind='file'] {
    height: 0.9rem;
    border-radius: 0.08rem;
  }

  .hero__proof-file-icon[data-kind='file']::before {
    display: none;
  }

  .hero__proof-file-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hero__proof-file-meta {
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }

  .hero__proof-email {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    padding: 0.8rem 0.95rem;
    background: var(--color-paper);
    border-top: 1px solid var(--color-mist);
  }

  .hero__proof-email-label {
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .hero__proof-email-meta {
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-signal);
    letter-spacing: 0.01em;
  }

  @keyframes hero-meter {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__proof {
      box-shadow: none;
    }

    .hero__proof-meter-fill {
      animation: none;
    }
  }
</style>

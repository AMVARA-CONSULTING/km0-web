---
const items = [
  {
    title: 'Punto de origen',
    desc: 'El pin representa el punto de partida: el Kilómetro 0 desde el que todo comienza.',
    icon: 'pin',
    delay: 0,
  },
  {
    title: 'Difusión',
    desc: 'Las ondas de señal simbolizan la difusión digital y el alcance de las ideas.',
    icon: 'signal',
    delay: 100,
  },
  {
    title: 'Red',
    desc: 'Los nodos conectados representan personas, ideas y oportunidades unidas.',
    icon: 'network',
    delay: 200,
  },
  {
    title: 'Transformación local',
    desc: 'Las ondas en la base evocan el impacto local con proyección global.',
    icon: 'ripple',
    delay: 300,
  },
];
---

<section id="significado" class="section-pad bg-white">
  <div class="mx-auto max-w-6xl">
    <p data-reveal class="mb-4 text-center text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      Significado
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-20 text-center text-navy">
      Más que un logo
    </h2>

    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.map((item, i) => (
          <article
            data-reveal
            data-delay={String(item.delay)}
            class="flex flex-col items-center text-center"
          >
            <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-2xl bg-surface">
              {item.icon === 'pin' && (
                <svg class="h-10 w-10" viewBox="0 0 40 40" fill="none">
                  <path
                    d="M20 4C14 4 10 9 10 14c0 8 10 18 10 18s10-10 10-18c0-5-4-10-10-10z"
                    stroke={`url(#grad-pin-${i})`}
                    stroke-width="2"
                    fill="none"
                  />
                  <circle cx="20" cy="14" r="3" fill={`url(#grad-pin-${i})`} />
                  <defs>
                    <linearGradient id={`grad-pin-${i}`} x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color="#FF5F2E" />
                      <stop offset="100%" stop-color="#007BFF" />
                    </linearGradient>
                  </defs>
                </svg>
              )}
              {item.icon === 'signal' && (
                <svg class="h-10 w-10 text-transparent" viewBox="0 0 40 40" fill="none" stroke={`url(#grad-sig-${i})`} stroke-width="2">
                  <path d="M8 28 Q20 8 32 28" />
                  <path d="M12 28 Q20 16 28 28" />
                  <defs>
                    <linearGradient id={`grad-sig-${i}`} x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="#E040A0" />
                      <stop offset="100%" stop-color="#7B3FE4" />
                    </linearGradient>
                  </defs>
                </svg>
              )}
              {item.icon === 'network' && (
                <svg class="h-10 w-10" viewBox="0 0 40 40" fill="none" stroke={`url(#grad-net-${i})`} stroke-width="2">
                  <circle cx="12" cy="20" r="3" fill="#7B3FE4" />
                  <circle cx="28" cy="12" r="3" fill="#007BFF" />
                  <circle cx="28" cy="28" r="3" fill="#FF5F2E" />
                  <line x1="15" y1="20" x2="25" y2="12" />
                  <line x1="15" y1="20" x2="25" y2="28" />
                  <defs>
                    <linearGradient id={`grad-net-${i}`} x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color="#7B3FE4" />
                      <stop offset="100%" stop-color="#007BFF" />
                    </linearGradient>
                  </defs>
                </svg>
              )}
              {item.icon === 'ripple' && (
                <svg class="h-10 w-10" viewBox="0 0 40 40" fill="none" stroke={`url(#grad-rip-${i})`} stroke-width="1.5" opacity="0.9">
                  <ellipse cx="20" cy="28" rx="16" ry="4" />
                  <ellipse cx="20" cy="28" rx="11" ry="3" />
                  <ellipse cx="20" cy="28" rx="6" ry="2" />
                  <defs>
                    <linearGradient id={`grad-rip-${i}`} x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="#007BFF" />
                      <stop offset="100%" stop-color="#22C1EE" />
                    </linearGradient>
                  </defs>
                </svg>
              )}
            </div>
            <h3 class="mb-3 text-lg font-semibold text-navy">{item.title}</h3>
            <p class="text-sm leading-relaxed text-navy/60">{item.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

---
import { MEETING_EVENTS } from '../lib/meetings';
import type { Locale, Messages } from '../i18n/types';
import { localeBcp47 } from '../i18n/types';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages } = Astro.props;
const m = messages.meeting;

const now = new Date();
const initialYear = now.getFullYear();
const initialMonth = now.getMonth();

const calendarEvents = MEETING_EVENTS.map((event) => ({
  id: event.id,
  date: event.date,
  time: event.time,
  tag: event.tag,
  mapsUrl: event.mapsUrl,
  venueWebsite: event.venueWebsite ?? '',
}));

const eventCopy = Object.fromEntries(
  MEETING_EVENTS.map((event) => [event.id, m.events[event.id]]),
);

const calendarPayload = JSON.stringify({
  locale: localeBcp47[locale],
  initialYear,
  initialMonth,
  events: calendarEvents,
  eventCopy,
  tags: m.tags,
  labels: m.labels,
  prevMonth: m.prevMonth,
  nextMonth: m.nextMonth,
  closeDetail: m.closeDetail,
});
---

<div class="meeting-calendar" data-meeting-calendar data-payload={calendarPayload}>
  <div class="meeting-calendar-toolbar">
    <button type="button" class="meeting-calendar-nav" data-cal-prev aria-label={m.prevMonth}>
      ‹
    </button>
    <h3 class="meeting-calendar-month" data-cal-title></h3>
    <button type="button" class="meeting-calendar-nav" data-cal-next aria-label={m.nextMonth}>
      ›
    </button>
  </div>
  <div class="meeting-calendar-weekdays" data-cal-weekdays aria-hidden="true"></div>
  <div class="meeting-calendar-grid" data-cal-grid role="grid" aria-label={m.calendarTitle}></div>
  <div class="meeting-calendar-detail" data-cal-detail hidden>
    <button type="button" class="meeting-calendar-detail-close" data-cal-close>
      {m.closeDetail}
    </button>
    <div data-cal-detail-body></div>
  </div>
</div>

<script>
  interface CalendarEvent {
    id: string;
    date: string;
    time: string;
    tag: string;
    mapsUrl: string;
    venueWebsite: string;
  }

  interface EventCopy {
    title: string;
    location: string;
    audience: string;
    topic: string;
  }

  interface CalendarPayload {
    locale: string;
    initialYear: number;
    initialMonth: number;
    events: CalendarEvent[];
    eventCopy: Record<string, EventCopy>;
    tags: Record<string, string>;
    labels: Record<string, string>;
    prevMonth: string;
    nextMonth: string;
    closeDetail: string;
  }

  function parsePayload(root: HTMLElement): CalendarPayload {
    const raw = root.dataset.payload;
    if (!raw) throw new Error('Missing calendar payload');
    return JSON.parse(raw) as CalendarPayload;
  }

  function isoFromParts(year: number, month: number, day: number): string {
    return `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  }

  function initCalendar(root: HTMLElement) {
    const payload = parsePayload(root);
    const titleEl = root.querySelector<HTMLElement>('[data-cal-title]');
    const weekdaysEl = root.querySelector<HTMLElement>('[data-cal-weekdays]');
    const gridEl = root.querySelector<HTMLElement>('[data-cal-grid]');
    const detailEl = root.querySelector<HTMLElement>('[data-cal-detail]');
    const detailBody = root.querySelector<HTMLElement>('[data-cal-detail-body]');
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-cal-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-cal-next]');
    const closeBtn = root.querySelector<HTMLButtonElement>('[data-cal-close]');
    if (!titleEl || !weekdaysEl || !gridEl || !detailEl || !detailBody || !prevBtn || !nextBtn || !closeBtn) {
      return;
    }

    let viewYear = payload.initialYear;
    let viewMonth = payload.initialMonth;

    const monthFormatter = new Intl.DateTimeFormat(payload.locale, { month: 'long', year: 'numeric' });
    const weekdayFormatter = new Intl.DateTimeFormat(payload.locale, { weekday: 'short' });

    const eventsByDate = new Map<string, CalendarEvent[]>();
    payload.events.forEach((event) => {
      const list = eventsByDate.get(event.date) ?? [];
      list.push(event);
      eventsByDate.set(event.date, list);
    });

    const hideDetail = () => {
      detailEl.hidden = true;
      detailBody.innerHTML = '';
    };

    const showDetail = (events: CalendarEvent[]) => {
      const parts = events
        .map((event) => {
          const copy = payload.eventCopy[event.id];
          if (!copy) return '';
          const websiteRow = event.venueWebsite
            ? `<div><dt>${payload.labels.website}</dt><dd><a href="${event.venueWebsite}" target="_blank" rel="noopener noreferrer">${event.venueWebsite.replace(/^https?:\/\//, '')}</a></dd></div>`
            : '';
          return `
            <article class="meeting-calendar-detail-item">
              <p class="meeting-calendar-detail-tag">${payload.tags[event.tag] ?? event.tag}</p>
              <h4>${copy.title}</h4>
              <dl>
                <div><dt>${payload.labels.time}</dt><dd>${event.time}</dd></div>
                <div><dt>${payload.labels.where}</dt><dd><a href="${event.mapsUrl}" target="_blank" rel="noopener noreferrer">${copy.location}</a></dd></div>
                ${websiteRow}
                <div><dt>${payload.labels.audience}</dt><dd>${copy.audience}</dd></div>
                <div><dt>${payload.labels.topic}</dt><dd>${copy.topic}</dd></div>
              </dl>
            </article>
          `;
        })
        .join('');
      detailBody.innerHTML = parts;
      detailEl.hidden = false;
    };

    const renderWeekdays = () => {
      const monday = new Date(2024, 0, 1);
      weekdaysEl.innerHTML = Array.from({ length: 7 }, (_, index) => {
        const day = new Date(monday);
        day.setDate(monday.getDate() + index);
        const label = weekdayFormatter.format(day);
        return `<span>${label.replace('.', '')}</span>`;
      }).join('');
    };

    const renderMonth = () => {
      titleEl.textContent = monthFormatter.format(new Date(viewYear, viewMonth, 1));
      gridEl.innerHTML = '';

      const firstDay = new Date(viewYear, viewMonth, 1);
      const startOffset = (firstDay.getDay() + 6) % 7;
      const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

      for (let i = 0; i < startOffset; i += 1) {
        const pad = document.createElement('div');
        pad.className = 'meeting-calendar-cell meeting-calendar-cell-empty';
        pad.setAttribute('aria-hidden', 'true');
        gridEl.appendChild(pad);
      }

      for (let day = 1; day <= daysInMonth; day += 1) {
        const iso = isoFromParts(viewYear, viewMonth, day);
        const dayEvents = eventsByDate.get(iso) ?? [];
        const cell = document.createElement('button');
        cell.type = 'button';
        cell.className = 'meeting-calendar-cell';
        cell.dataset.date = iso;
        cell.setAttribute('role', 'gridcell');
        if (dayEvents.length > 0) {
          cell.innerHTML = `<span class="meeting-calendar-day-wrap"><span class="meeting-calendar-day">${day}</span><span class="meeting-calendar-event-dot" aria-hidden="true"></span></span>`;
          cell.classList.add('meeting-calendar-cell-has-event');
          cell.setAttribute('aria-label', `${dayEvents.map((e) => payload.eventCopy[e.id]?.title ?? e.id).join(', ')}`);
          cell.addEventListener('click', () => showDetail(dayEvents));
        } else {
          cell.innerHTML = `<span class="meeting-calendar-day">${day}</span>`;
          cell.disabled = true;
          cell.classList.add('meeting-calendar-cell-muted');
        }

        gridEl.appendChild(cell);
      }
    };

    prevBtn.addEventListener('click', () => {
      viewMonth -= 1;
      if (viewMonth < 0) {
        viewMonth = 11;
        viewYear -= 1;
      }
      hideDetail();
      renderMonth();
    });

    nextBtn.addEventListener('click', () => {
      viewMonth += 1;
      if (viewMonth > 11) {
        viewMonth = 0;
        viewYear += 1;
      }
      hideDetail();
      renderMonth();
    });

    closeBtn.addEventListener('click', hideDetail);

    renderWeekdays();
    renderMonth();
  }

  document.querySelectorAll<HTMLElement>('[data-meeting-calendar]').forEach(initCalendar);
</script>

<style>
  .meeting-calendar {
    padding: 1.25rem 1.375rem 1.5rem;
    border: 1px solid var(--color-mist);
    background: var(--color-snow);
  }

  .meeting-calendar-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .meeting-calendar-month {
    margin: 0;
    font-family: theme('fontFamily.display');
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-ink);
    text-transform: capitalize;
  }

  .meeting-calendar-nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--color-mist);
    border-radius: 0.375rem;
    background: var(--color-snow);
    color: var(--color-ink);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .meeting-calendar-nav:hover {
    background: var(--color-paper);
    border-color: color-mix(in srgb, var(--color-ink) 25%, transparent);
  }

  .meeting-calendar-nav:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 2px;
  }

  .meeting-calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.25rem;
    margin-bottom: 0.5rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    text-align: center;
  }

  .meeting-calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.25rem;
  }

  /* Day cells are rendered client-side; use :global so Astro scope attrs are not required. */
  .meeting-calendar :global(.meeting-calendar-cell) {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--color-ink);
    font-size: 0.9375rem;
    cursor: default;
  }

  .meeting-calendar :global(.meeting-calendar-day-wrap) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    pointer-events: none;
  }

  .meeting-calendar :global(.meeting-calendar-event-dot) {
    display: block;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 9999px;
    background: var(--color-signal);
  }

  .meeting-calendar :global(.meeting-calendar-cell-has-event) {
    cursor: pointer;
    border-color: color-mix(in srgb, var(--color-signal) 45%, transparent);
    background: color-mix(in srgb, var(--color-signal) 12%, transparent);
    font-weight: 700;
  }

  .meeting-calendar :global(.meeting-calendar-cell-has-event:hover) {
    border-color: color-mix(in srgb, var(--color-signal) 60%, transparent);
    background: color-mix(in srgb, var(--color-signal) 18%, transparent);
  }

  .meeting-calendar :global(.meeting-calendar-cell-has-event:focus-visible) {
    outline: 2px solid var(--color-signal);
    outline-offset: 1px;
  }

  .meeting-calendar :global(.meeting-calendar-cell-muted) {
    color: color-mix(in srgb, var(--color-ink) 35%, transparent);
  }

  .meeting-calendar :global(.meeting-calendar-cell-empty) {
    min-height: 2.5rem;
  }

  .meeting-calendar :global(.meeting-calendar-day) {
    pointer-events: none;
  }

  .meeting-calendar-detail {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-mist);
  }

  .meeting-calendar-detail-close {
    margin-bottom: 0.875rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-mist);
    border-radius: 0.375rem;
    background: var(--color-snow);
    color: var(--color-ink);
    font-family: theme('fontFamily.sans');
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
  }

  .meeting-calendar-detail-close:hover {
    background: var(--color-paper);
  }

  :global(.meeting-calendar-detail-item) {
    padding: 0.25rem 0;
  }

  :global(.meeting-calendar-detail-item + .meeting-calendar-detail-item) {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-mist);
  }

  :global(.meeting-calendar-detail-tag) {
    margin: 0 0 0.35rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  :global(.meeting-calendar-detail-item h4) {
    margin: 0 0 0.75rem;
    font-family: theme('fontFamily.display');
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  :global(.meeting-calendar-detail-item dl) {
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  :global(.meeting-calendar-detail-item dt) {
    font-family: theme('fontFamily.sans');
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  :global(.meeting-calendar-detail-item dd) {
    margin: 0.1rem 0 0;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }

  :global(.meeting-calendar-detail-item a) {
    color: var(--color-ink);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
</style>

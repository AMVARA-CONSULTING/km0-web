---
import type { Messages } from '../i18n/types';

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;
---

<section id="mission" class="section-pad bg-surface">
  <div class="mx-auto max-w-3xl text-center">
    <p data-reveal class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.mission.eyebrow}
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-12 text-navy">
      {m.mission.heading}
    </h2>
    <p
      data-reveal
      data-delay="160"
      class="text-lg leading-relaxed text-navy/70 md:text-xl md:leading-relaxed"
    >
      {m.mission.body}
    </p>
  </div>
</section>

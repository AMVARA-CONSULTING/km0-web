---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeHref } from '../i18n/paths';
import ServiceComingSoonModal from './ServiceComingSoonModal.astro';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const hasComingSoon = m.services.items.some((item) => item.available === false);

const icons: Record<string, string> = {
  cloud: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  email: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
};
---

<section id="services" class="section-pad bg-white">
  <div class="mx-auto max-w-6xl text-center">
    <p data-reveal class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.services.eyebrow}
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-6 text-navy">
      {m.services.headingBefore}<span class="text-gradient">{m.services.headingAccent}</span>{m.services.headingAfter}
    </h2>
    <p data-reveal data-delay="120" class="mx-auto mb-4 max-w-2xl text-lg text-navy/70">
      {m.services.intro}
    </p>
    <p data-reveal data-delay="160" class="mb-14 text-base font-semibold text-navy">
      {m.services.slogan}
    </p>

    <div class="grid gap-8 md:grid-cols-2 md:text-left">
      {
        m.services.items.map((item, i) => (
          <article
            data-reveal
            data-delay={String(200 + i * 80)}
            class="flex flex-col rounded-2xl border border-navy/10 bg-surface p-8 shadow-sm"
          >
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-white text-navy">
              <svg
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={icons[item.id] ?? icons.cloud} />
              </svg>
            </div>
            <h3 class="mb-3 text-xl font-semibold text-navy">{item.title}</h3>
            <p class="mb-6 flex-grow text-navy/70">{item.desc}</p>
            {item.id === 'cloud' && (
              <a
                href={localeHref(locale, '/tutorials/getting-started-web/')}
                class="mb-3 inline-flex items-center gap-2 text-sm font-medium text-navy transition-colors hover:text-navy/70 md:self-start"
              >
                {m.services.cloudTutorialCta}
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            )}
            {item.available === false ? (
              <button
                type="button"
                data-service-coming-soon
                class="btn-primary inline-flex w-full justify-center md:w-auto md:self-start"
              >
                {item.cta}
              </button>
            ) : (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary inline-flex w-full justify-center md:w-auto md:self-start"
              >
                {item.cta}
              </a>
            )}
          </article>
        ))
      }
    </div>

    <p data-reveal data-delay="400" class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-8">
      <a
        href={localeHref(locale, '/tutorials/')}
        class="inline-flex items-center gap-2 text-sm font-medium text-navy transition-colors hover:text-navy/70"
      >
        {m.services.tutorialsCta}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href={localeHref(locale, '/doc/')}
        class="inline-flex items-center gap-2 text-sm font-medium text-navy transition-colors hover:text-navy/70"
      >
        {m.services.blogCta}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </p>
  </div>
</section>

{hasComingSoon && <ServiceComingSoonModal messages={m} />}

<script>
  import '../scripts/service-coming-soon.ts';
</script>

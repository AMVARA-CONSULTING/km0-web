---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeHref, withHash } from '../i18n/paths';
import ServiceComingSoonModal from './ServiceComingSoonModal.astro';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const hasComingSoon = m.services.items.some((item) => item.available === false);

const icons: Record<string, string> = {
  cloud:
    'M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.32-2.127 4.5 4.5 0 018.59 2.75L18 19.5H6.75z',
  email:
    'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
};
---

<section id="services" class="section-pad bg-white" aria-labelledby="services-heading">
  <div class="mx-auto max-w-6xl text-center">
    <p data-reveal class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.services.eyebrow}
    </p>
    <h2 id="services-heading" data-reveal data-delay="80" class="heading-section mb-6 text-navy">
      {m.services.headingBefore}<span class="text-gradient">{m.services.headingAccent}</span>{m.services.headingAfter}
    </h2>
    <p data-reveal data-delay="120" class="mx-auto mb-4 max-w-2xl text-lg text-navy/70">
      {m.services.intro}
    </p>
    <p data-reveal data-delay="160" class="mb-14 text-base font-semibold text-navy">
      {m.services.slogan}
    </p>

    <div class="grid gap-8 md:grid-cols-2 md:text-left">
      {
        m.services.items.map((item, i) => {
          const isCloud = item.id === 'cloud';
          const isEmail = item.id === 'email';
          const isFeatured = isCloud || (isEmail && item.available !== false);
          const primaryHref = item.ctaFragment
            ? withHash(locale, item.ctaFragment)
            : item.url;

          return (
            <article
              id={isCloud ? 'km0-cloud' : isEmail ? 'km0-email' : undefined}
              data-reveal
              data-delay={String(200 + i * 80)}
              class:list={[
                'service-card flex flex-col rounded-2xl border p-8 shadow-sm',
                isFeatured ? 'service-card-featured' : 'border-navy/10 bg-surface',
              ]}
            >
              <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-white text-navy">
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={icons[item.id] ?? icons.cloud} />
                </svg>
              </div>
              <h3 class="mb-2 text-xl font-semibold text-navy md:text-2xl">{item.title}</h3>
              {isCloud && item.priceFrom && (
                <p class="service-card-price tabular-nums" aria-label={item.priceAriaLabel}>
                  {item.priceFrom}
                </p>
              )}
              {item.subtitle && <p class="service-card-subtitle">{item.subtitle}</p>}
              <p class="mb-6 flex-grow text-navy/70">{item.desc}</p>
              {isCloud && (
                <a
                  href={localeHref(locale, '/tutorials/getting-started-web/')}
                  class="mb-4 inline-flex items-center gap-2 text-sm font-medium text-navy transition-colors hover:text-navy/70 md:self-start"
                >
                  {m.services.cloudTutorialCta}
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              )}
              <div class:list={['service-card-actions', isCloud && 'service-card-actions--paired']}>
                {!isCloud &&
                  (item.available === false ? (
                    <button
                      type="button"
                      data-service-coming-soon
                      class="btn-primary inline-flex w-full justify-center md:w-auto md:self-start"
                    >
                      {item.cta}
                    </button>
                  ) : item.ctaFragment ? (
                    <a href={primaryHref} class="btn-primary inline-flex w-full justify-center md:w-auto md:self-start">
                      {item.cta}
                    </a>
                  ) : (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-primary inline-flex w-full justify-center md:w-auto md:self-start"
                    >
                      {item.cta}
                    </a>
                  ))}
                {isCloud && (
                  <a
                    href={localeHref(locale, '/pricing/')}
                    class="service-card-secondary-cta inline-flex justify-center"
                  >
                    {m.services.cloudPricingCta}
                  </a>
                )}
                {isCloud && item.secondaryCta && (
                  <a
                    href={item.url}
                    class="btn-primary inline-flex justify-center"
                  >
                    {item.secondaryCta}
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

{hasComingSoon && <ServiceComingSoonModal messages={m} />}

<script>
  import '../scripts/service-coming-soon.ts';
</script>

<style>
  .service-card-featured {
    border-color: rgb(255 95 46 / 0.35);
    background: linear-gradient(180deg, rgb(255 95 46 / 0.06) 0%, #fff 42%);
    box-shadow: 0 12px 32px rgb(255 95 46 / 0.1);
  }

  .service-card-price {
    margin: 0 0 0.75rem;
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.2;
    color: #c2410c;
  }

  .service-card-subtitle {
    margin: 0 0 1rem;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    color: #0f172a;
  }

  .service-card-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
  }

  .service-card-actions--paired {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
  }

  @media (min-width: 768px) {
    .service-card-actions {
      align-items: flex-start;
    }

    .service-card-actions--paired {
      align-items: center;
    }
  }

  .service-card-secondary-cta {
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid rgb(15 23 42 / 0.14);
    background: #fff;
    padding: 0.75rem 2rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0f172a;
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .service-card-secondary-cta:hover {
    border-color: rgb(15 23 42 / 0.28);
    background: rgb(15 23 42 / 0.04);
  }

  .service-card-secondary-cta:focus-visible {
    outline: 2px solid #0f172a;
    outline-offset: 3px;
  }
</style>

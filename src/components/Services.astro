---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeHref, withHash } from '../i18n/paths';
import ServiceComingSoonModal from './ServiceComingSoonModal.astro';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const hasComingSoon = m.services.items.some((item) => item.available === false);
const cloudItem = m.services.items.find((item) => item.id === 'cloud');
const pinCta = cloudItem?.secondaryCta ?? m.hero.ctaPrimary;
const pinHref = cloudItem?.url ?? 'https://cloud.km0digital.com';
---

<section id="services" class="section-pad offer" aria-labelledby="services-heading">
  <div class="offer__layout mx-auto max-w-6xl">
    <aside class="offer__pin" data-offer-pin>
      <header class="offer__header" data-reveal>
        <h2 id="services-heading" class="heading-section text-navy">
          {m.services.headingBefore}<span class="text-gradient">{m.services.headingAccent}</span>{m.services.headingAfter}
        </h2>
        <p class="offer__intro">{m.services.intro}</p>
        <p class="offer__slogan">{m.services.slogan}</p>
      </header>
      <a href={pinHref} class="btn-primary offer__pin-cta" data-reveal data-delay="100">
        {pinCta}
      </a>
    </aside>

    <div class="offer__list">
      {
        m.services.items.map((item, i) => {
          const isCloud = item.id === 'cloud';
          const isEmail = item.id === 'email';
          const primaryHref = item.ctaFragment
            ? withHash(locale, item.ctaFragment)
            : item.url;

          return (
            <article
              id={isCloud ? 'km0-cloud' : isEmail ? 'km0-email' : undefined}
              data-reveal
              data-delay={String(80 + i * 80)}
              class="offer-row"
            >
              <div class="offer-row__lead">
                <p class="offer-row__meta">{isCloud ? '01' : '02'}</p>
                <h3 class="offer-row__title">{item.title}</h3>
                {isCloud && item.priceFrom && (
                  <p class="offer-row__price" aria-label={item.priceAriaLabel}>
                    {item.priceFrom}
                  </p>
                )}
                {item.subtitle && <p class="offer-row__subtitle">{item.subtitle}</p>}
              </div>
              <div class="offer-row__body">
                <p class="offer-row__desc">{item.desc}</p>
                {isCloud && (
                  <a
                    href={localeHref(locale, '/tutorials/getting-started-web/')}
                    class="offer-row__text-link"
                  >
                    {m.services.cloudTutorialCta}
                  </a>
                )}
                <div class:list={['offer-row__actions', isCloud && 'offer-row__actions--paired']}>
                  {!isCloud &&
                    (item.available === false ? (
                      <button type="button" data-service-coming-soon class="btn-primary">
                        {item.cta}
                      </button>
                    ) : item.ctaFragment ? (
                      <a href={primaryHref} class="btn-primary">
                        {item.cta}
                      </a>
                    ) : (
                      <a
                        href={item.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-primary"
                      >
                        {item.cta}
                      </a>
                    ))}
                  {isCloud && (
                    <a href={localeHref(locale, '/pricing/')} class="offer-row__text-link">
                      {m.services.cloudPricingCta}
                    </a>
                  )}
                  {isCloud && item.secondaryCta && (
                    <a href={item.url} class="btn-primary">
                      {item.secondaryCta}
                    </a>
                  )}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

{hasComingSoon && <ServiceComingSoonModal messages={m} />}

<script>
  import '../scripts/service-coming-soon.ts';
</script>

<style>
  .offer__layout {
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 1024px) {
    .offer__layout {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.2fr);
      gap: 3.5rem;
      align-items: start;
    }

    .offer__pin {
      position: sticky;
      top: var(--masthead-offset);
      padding-bottom: 1rem;
    }
  }

  :global(html[data-masthead='compact']) .offer__pin {
    top: var(--masthead-offset-compact);
  }

  .offer__header {
    max-width: 40rem;
    margin-bottom: 0;
  }

  .offer__pin-cta {
    display: none;
    margin-top: 1.75rem;
  }

  @media (min-width: 1024px) {
    .offer__pin-cta {
      display: inline-flex;
    }
  }

  .offer__intro {
    margin: 1rem 0 0;
    font-size: 1.125rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }

  .offer__slogan {
    margin: 0.75rem 0 0;
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-signal);
  }

  .offer__list {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-mist);
  }

  @media (max-width: 1023px) {
    .offer__header {
      margin-bottom: 2.5rem;
    }
  }

  .offer-row {
    display: grid;
    gap: 1.25rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-mist);
  }

  @media (min-width: 768px) {
    .offer-row {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 2.5rem;
      align-items: start;
      padding: 2.5rem 0;
    }
  }

  .offer-row__meta {
    margin: 0 0 0.5rem;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, monospace;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--color-signal);
  }

  .offer-row__title {
    margin: 0;
    font-family: theme('fontFamily.display');
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .offer-row__price {
    margin: 0.5rem 0 0;
    font-family: theme('fontFamily.sans');
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-signal);
  }

  .offer-row__subtitle {
    margin: 0.5rem 0 0;
    font-family: theme('fontFamily.sans');
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .offer-row__desc {
    margin: 0 0 1rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }

  .offer-row__text-link {
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: rgb(15 118 110 / 0.4);
    text-underline-offset: 0.18em;
  }

  .offer-row__text-link:hover {
    color: var(--color-signal);
    text-decoration-color: var(--color-signal);
  }

  .offer-row__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1.25rem;
    margin-top: 1rem;
  }

  .offer-row__actions--paired {
    flex-direction: row;
  }
</style>

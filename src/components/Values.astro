---
import type { Messages } from '../i18n/types';

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;

const delays = [0, 80, 160, 240];
const chips = m.values.chips.map((label, i) => ({
  label,
  delay: delays[i] ?? 0,
}));
---

<section id="valores" class="section-pad bg-surface">
  <div class="mx-auto max-w-6xl text-center">
    <p data-reveal class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.values.eyebrow}
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-16 text-navy">
      {m.values.headingBefore}<span class="text-gradient">{m.values.headingAccent}</span>{m.values.headingAfter}
    </h2>

    <div class="flex flex-wrap justify-center gap-4 md:gap-6">
      {
        chips.map((v) => (
          <span
            data-reveal
            data-delay={String(v.delay)}
            class="chip text-base md:text-lg"
          >
            {v.label}
          </span>
        ))
      }
    </div>
  </div>
</section>

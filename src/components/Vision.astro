---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeHref } from '../i18n/paths';

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages: m } = Astro.props;
const delays = [0, 80, 160, 240];
---

<section id="vision" class="section-pad bg-white">
  <div class="mx-auto max-w-6xl">
    <p data-reveal class="mb-4 text-center text-sm font-medium uppercase tracking-[0.2em] text-navy/50">
      {m.vision.eyebrow}
    </p>
    <h2 data-reveal data-delay="80" class="heading-section mb-6 text-center text-navy">
      {m.vision.headingBefore}<span class="text-gradient">{m.vision.headingAccent}</span>{m.vision.headingAfter}
    </h2>
    <p data-reveal data-delay="120" class="mx-auto mb-16 max-w-2xl text-center text-lg text-navy/70">
      {m.vision.intro}
    </p>

    <div class="grid gap-8 md:grid-cols-2">
      <article
        data-reveal
        data-delay="160"
        class="rounded-2xl border border-navy/10 bg-surface p-8"
      >
        <h3 class="mb-6 text-lg font-semibold text-navy/50">{m.vision.usual.title}</h3>
        <ul class="space-y-4">
          {
            m.vision.usual.items.map((item, i) => (
              <li class="flex items-start gap-3 text-navy/70">
                <span
                  class="mt-1.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-navy/10 text-xs text-navy/40"
                  aria-hidden="true"
                >
                  ×
                </span>
                <span data-reveal data-delay={String(delays[i] ?? 0)}>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>

      <article
        data-reveal
        data-delay="240"
        class="rounded-2xl border border-navy/10 bg-navy p-8 text-white"
      >
        <h3 class="mb-6 text-lg font-semibold text-white/70">{m.vision.km0.title}</h3>
        <ul class="space-y-4">
          {
            m.vision.km0.items.map((item, i) => (
              <li class="flex items-start gap-3 text-white/85">
                <span
                  class="mt-1.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-white/15 text-xs text-white"
                  aria-hidden="true"
                >
                  ✓
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>

    <p data-reveal data-delay="320" class="mt-12 text-center">
      <a
        href={localeHref(locale, '/doc/')}
        class="inline-flex items-center gap-2 text-sm font-medium text-navy transition-colors hover:text-navy/70"
      >
        {m.vision.blogCta}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </p>
  </div>
</section>

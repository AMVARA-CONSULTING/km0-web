---
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';

interface Props {
  locale: Locale;
  messages: Messages;
  canonicalUrl: string;
  pageTitle?: string;
  pageDescription?: string;
}

const site = Astro.site ?? new URL('https://km0.amvara.de');

const hrefs: Record<Locale, string> = {
  es: new URL('/', site).href,
  ca: new URL('/ca/', site).href,
  en: new URL('/en/', site).href,
};

const langAttr: Record<Locale, string> = {
  es: 'es',
  ca: 'ca',
  en: 'en',
};

const { locale, messages: m, canonicalUrl, pageTitle, pageDescription } = Astro.props;
const title = pageTitle ?? m.meta.title;
const description = pageDescription ?? m.meta.description;
---

<!doctype html>
<html lang={langAttr[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={hrefs.es} />
    <link rel="alternate" hreflang="ca" href={hrefs.ca} />
    <link rel="alternate" hreflang="en" href={hrefs.en} />
    <link rel="alternate" hreflang="x-default" href={hrefs.es} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://km0.amvara.de/brand/logo.png" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={langAttr[locale]} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/scroll-reveal.ts';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

---
import '../styles/global.css';
import SeoManager from '../components/SeoManager.astro';
import type { Locale } from '../i18n/types';
import type { Messages } from '../i18n/types';
import { localeBcp47 } from '../i18n/types';

interface Props {
  locale: Locale;
  messages: Messages;
  canonicalUrl: string;
  pageTitle?: string;
  pageDescription?: string;
}

const site = Astro.site ?? new URL('https://km0digital.com');

const hrefs: Record<Locale, string> = {
  es: new URL('/', site).href,
  ca: new URL('/ca/', site).href,
  en: new URL('/en/', site).href,
  de: new URL('/de/', site).href,
};

const { locale, messages: m, canonicalUrl, pageTitle, pageDescription } = Astro.props;
const title = pageTitle ?? m.meta.title;
const description = pageDescription ?? m.meta.description;
---

<!doctype html>
<html lang={localeBcp47[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <SeoManager
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      imageAlt={m.brandNameShort}
      locale={localeBcp47[locale]}
    />
    <link rel="alternate" hreflang="es" href={hrefs.es} />
    <link rel="alternate" hreflang="ca" href={hrefs.ca} />
    <link rel="alternate" hreflang="en" href={hrefs.en} />
    <link rel="alternate" hreflang="de" href={hrefs.de} />
    <link rel="alternate" hreflang="x-default" href={hrefs.es} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/scroll-reveal.ts';
    </script>
  </body>
</html>

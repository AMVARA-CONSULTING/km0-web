---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import { fetchCloudUserCount } from '../lib/cloud-users';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const countResult = await fetchCloudUserCount();

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/cloud/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={messages.cloudUsers.metaTitle}
  pageDescription={messages.cloudUsers.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="section-pad bg-white pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <header class="mb-12">
        <p class="doc-eyebrow">{messages.cloudUsers.eyebrow}</p>
        <h1 class="heading-section text-navy">{messages.cloudUsers.heading}</h1>
        <p class="doc-index-intro mt-6" set:html={messages.cloudUsers.intro} />
      </header>

      {
        countResult.ok ? (
          <div class="cloud-users-stat" aria-live="polite">
            <p
              class="cloud-users-count cloud-users-count-gradient tabular-nums"
              aria-label={messages.cloudUsers.countAria.replace('{count}', String(countResult.count))}
            >
              {countResult.count.toLocaleString(locale === 'de' ? 'de-DE' : locale === 'en' ? 'en-GB' : locale === 'ca' ? 'ca-ES' : 'es-ES')}
            </p>
            <p class="mt-4 text-lg font-medium text-navy/80">{messages.cloudUsers.countLabel}</p>
          </div>
        ) : (
          <p class="text-lg text-navy/60">{messages.cloudUsers.unavailable}</p>
        )
      }

    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

<style>
  .cloud-users-count {
    font-size: clamp(4rem, 18vw, 8rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .cloud-users-count-gradient {
    background: linear-gradient(
      90deg,
      #ff5f2e 0%,
      #e040a0 25%,
      #7b3fe4 50%,
      #007bff 75%,
      #ff5f2e 100%
    );
    background-size: 250% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    animation: cloud-users-gradient-flow 7s ease-in-out infinite;
  }

  @keyframes cloud-users-gradient-flow {
    0%,
    100% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cloud-users-count-gradient {
      animation: none;
      background-position: 0% 50%;
    }
  }
</style>

---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, docPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import { getCollection } from 'astro:content';
import { docSlug, formatDocDate, compareDocPosts } from '../lib/doc';
import { estimateReadingMinutes, formatReadingTime } from '../lib/reading';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const posts = (await getCollection('doc', ({ data }) => data.locale === locale)).sort(
  compareDocPosts,
);

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/doc/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={messages.doc.metaTitle}
  pageDescription={messages.doc.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="section-pad doc-reading-page pt-28">
    <div class="doc-index mx-auto max-w-3xl">
      <header class="doc-index-header">
        <p class="doc-eyebrow">{messages.doc.eyebrow}</p>
        <h1 class="heading-section text-navy">{messages.doc.heading}</h1>
        <p class="doc-index-intro">{messages.doc.intro}</p>
      </header>

      <ul class="doc-post-list">
        {
          posts.map((post) => {
            const readingMinutes = estimateReadingMinutes(post.body ?? '', locale);
            const readingTime = formatReadingTime(messages.doc.readingTime, readingMinutes);

            return (
              <li class="doc-post-card">
                <div class="doc-post-card-meta">
                  <time datetime={post.data.pubDate.toISOString()} class="doc-date">
                    {formatDocDate(post.data.pubDate, locale)}
                  </time>
                  <span class="doc-reading-time">{readingTime}</span>
                </div>
                <h2 class="doc-post-card-title">
                  <a href={docPostHref(locale, docSlug(post))}>{post.data.title}</a>
                </h2>
                <p class="doc-post-card-desc">{post.data.description}</p>
                <a href={docPostHref(locale, docSlug(post))} class="doc-read-more">
                  {messages.doc.readMore}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

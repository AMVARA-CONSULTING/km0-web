---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, docPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import { getCollection } from 'astro:content';
import { docSlug, formatDocDate } from '../lib/doc';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const posts = (await getCollection('doc', ({ data }) => data.locale === locale)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const siteRoot = Astro.site ?? new URL('https://km0.amvara.de');
const canonicalUrl = new URL(localeHref(locale, '/doc/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={messages.doc.metaTitle}
  pageDescription={messages.doc.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="section-pad bg-white pt-28">
    <div class="doc-index mx-auto max-w-4xl text-justify">
      <header class="doc-index-header mb-12">
        <p class="doc-eyebrow">{messages.doc.eyebrow}</p>
        <h1 class="heading-section text-navy">{messages.doc.heading}</h1>
        <p class="doc-index-intro">{messages.doc.intro}</p>
      </header>

      <ul class="doc-post-list">
        {
          posts.map((post) => (
            <li class="doc-post-card">
              <time datetime={post.data.pubDate.toISOString()} class="doc-date">
                {formatDocDate(post.data.pubDate, locale)}
              </time>
              <h2 class="doc-post-card-title">
                <a href={docPostHref(locale, docSlug(post))}>{post.data.title}</a>
              </h2>
              <p class="doc-post-card-desc">{post.data.description}</p>
              <a href={docPostHref(locale, docSlug(post))} class="doc-read-more">
                {messages.doc.readMore}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, docPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import { getCollection } from 'astro:content';
import { docSlug, formatDocDate, compareDocPosts } from '../lib/doc';
import { estimateReadingMinutes, formatReadingTime } from '../lib/reading';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const posts = (await getCollection('doc', ({ data }) => data.locale === locale)).sort(
  compareDocPosts,
);

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/doc/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={messages.doc.metaTitle}
  pageDescription={messages.doc.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="reading-page">
    <div class="reading-index">
      <header class="reading-index-masthead">
        <p class="reading-index-label">{messages.doc.eyebrow}</p>
        <h1 class="reading-index-title">{messages.doc.heading}</h1>
        <p class="reading-index-dek">{messages.doc.intro}</p>
      </header>

      <ul class="reading-catalog">
        {
          posts.map((post, index) => {
            const readingMinutes = estimateReadingMinutes(post.body ?? '', locale);
            const readingTime = formatReadingTime(messages.doc.readingTime, readingMinutes);

            return (
              <li class:list={['reading-entry', index === 0 && 'reading-entry--feature']}>
                <h2 class="reading-entry-title">
                  <a href={docPostHref(locale, docSlug(post))}>{post.data.title}</a>
                </h2>
                <p class="reading-entry-dek">{post.data.description}</p>
                <div class="reading-entry-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDocDate(post.data.pubDate, locale)}
                  </time>
                  <span>{readingTime}</span>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

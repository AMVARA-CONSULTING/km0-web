---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, docPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import type { CollectionEntry } from 'astro:content';
import { docSlug, formatDocDate } from '../lib/doc';

interface Props {
  locale: Locale;
  post: CollectionEntry<'doc'>;
}

const { locale, post } = Astro.props;
const messages = getMessages(locale);
const { Content } = await post.render();

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const postPath = docPostHref(locale, docSlug(post));
const canonicalUrl = new URL(postPath, siteRoot).href;
const pageTitle = `${post.data.title} - ${messages.brandNameShort}`;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={pageTitle}
  pageDescription={post.data.description}
>
  <Header locale={locale} messages={messages} />
  <main class="section-pad bg-white pt-28">
    <article class="doc-article mx-auto max-w-4xl">
      <nav class="doc-breadcrumb mb-10" aria-label="Breadcrumb">
        <a href={localeHref(locale, '/doc/')} class="doc-breadcrumb-link">
          {messages.doc.breadcrumbHome}
        </a>
        <span class="doc-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="doc-breadcrumb-current">{post.data.title}</span>
      </nav>

      <header class="doc-header mb-12">
        <time datetime={post.data.pubDate.toISOString()} class="doc-date">
          {formatDocDate(post.data.pubDate, locale)}
        </time>
        <h1 class="heading-section doc-title text-navy">{post.data.title}</h1>
        <p class="doc-dek text-justify">{post.data.description}</p>
      </header>

      <div class="doc-body">
        <Content />
      </div>

      <footer class="doc-footer">
        <a href={localeHref(locale, '/doc/')} class="doc-back">
          {messages.doc.backToIndex}
        </a>
      </footer>
    </article>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import DocArticleChrome from '../components/DocArticleChrome.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, docPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { docSlug, formatDocDate, compareDocPosts } from '../lib/doc';
import { extractDocToc, estimateReadingMinutes } from '../lib/reading';

interface Props {
  locale: Locale;
  post: CollectionEntry<'doc'>;
}

const { locale, post } = Astro.props;
const messages = getMessages(locale);
const { Content } = await post.render();

const posts = (await getCollection('doc', ({ data }) => data.locale === locale)).sort(
  compareDocPosts,
);
const postIndex = posts.findIndex((entry) => entry.id === post.id);
const olderPost = postIndex < posts.length - 1 ? posts[postIndex + 1] : undefined;
const newerPost = postIndex > 0 ? posts[postIndex - 1] : undefined;
const relatedPosts = posts.filter((entry) => entry.id !== post.id).slice(0, 2);

const toc = extractDocToc(post.body ?? '');
const readingMinutes = estimateReadingMinutes(post.body ?? '', locale);

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const postPath = docPostHref(locale, docSlug(post));
const canonicalUrl = new URL(postPath, siteRoot).href;
const pageTitle = `${post.data.title} - ${messages.brandNameShort}`;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={pageTitle}
  pageDescription={post.data.description}
>
  <Header locale={locale} messages={messages} />
  <main class="section-pad doc-reading-page pt-28">
    <DocArticleChrome
      breadcrumbHome={messages.doc.breadcrumbHome}
      breadcrumbHomeHref={localeHref(locale, '/doc/')}
      title={post.data.title}
      description={post.data.description}
      readingTimeLabel={messages.doc.readingTime}
      readingMinutes={readingMinutes}
      tocTitle={messages.doc.tocTitle}
      toc={toc}
      prevLabel={messages.doc.previousPost}
      nextLabel={messages.doc.nextPost}
      backHref={localeHref(locale, '/doc/')}
      backLabel={messages.doc.backToIndex}
      relatedTitle={messages.doc.relatedPosts}
      pubDate={post.data.pubDate}
      pubDateLabel={formatDocDate(post.data.pubDate, locale)}
      prev={
        olderPost
          ? { href: docPostHref(locale, docSlug(olderPost)), title: olderPost.data.title }
          : undefined
      }
      next={
        newerPost
          ? { href: docPostHref(locale, docSlug(newerPost)), title: newerPost.data.title }
          : undefined
      }
      related={relatedPosts.map((entry) => ({
        href: docPostHref(locale, docSlug(entry)),
        title: entry.data.title,
        description: entry.data.description,
      }))}
    >
      <Content />
    </DocArticleChrome>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

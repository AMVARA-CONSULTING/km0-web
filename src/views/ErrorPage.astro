---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';

type ErrorStatus = '404' | '403';

interface Props {
  locale: Locale;
  status: ErrorStatus;
}

const { locale, status } = Astro.props;
const messages = getMessages(locale);
const errorContent =
  status === '404' ? messages.errors.notFound : messages.errors.forbidden;

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/'), siteRoot).href;
const homeHref = localeHref(locale, '/');
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={errorContent.metaTitle}
  pageDescription={errorContent.description}
>
  <Header locale={locale} messages={messages} />
  <main class="page-shell">
    <div class="section-pad !pt-10 md:!pt-14">
      <div class="page-inner !px-0">
        <header class="page-masthead error-masthead" data-reveal>
          <p class="doc-kicker">{errorContent.code}</p>
          <h1 class="heading-page text-ink">{errorContent.heading}</h1>
          <p class="doc-index-intro">{errorContent.description}</p>
          <div class="page-closer__actions">
            <a href={homeHref} class="btn-primary">{errorContent.backHome}</a>
          </div>
        </header>
      </div>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

<style>
  .error-masthead {
    max-width: 36rem;
  }

  .error-masthead .heading-page {
    max-width: 18ch;
  }
</style>

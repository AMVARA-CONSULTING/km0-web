---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import IdeasForm from '../components/IdeasForm.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/ideas/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={messages.ideas.metaTitle}
  pageDescription={messages.ideas.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="page-shell">
    <div class="section-pad !pt-10 md:!pt-14">
      <div class="page-inner !px-0">
        <header class="page-masthead" data-reveal>
          <h1 class="heading-section text-ink">{messages.ideas.heading}</h1>
          <p class="doc-index-intro">{messages.ideas.intro}</p>
        </header>
        <div data-reveal data-delay="80">
          <IdeasForm locale={locale} messages={messages} />
        </div>
      </div>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

---
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustSignals from '../components/TrustSignals.astro';
import Services from '../components/Services.astro';
import CloudUserStats from '../components/CloudUserStats.astro';
import WhyKm0 from '../components/WhyKm0.astro';
import Community from '../components/Community.astro';
import Faq from '../components/Faq.astro';
import Contact from '../components/Contact.astro';
import Purpose from '../components/Purpose.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl =
  locale === 'es'
    ? new URL('/', siteRoot).href
    : new URL(`${locale}/`, siteRoot).href;
---

<Layout locale={locale} messages={messages} canonicalUrl={canonicalUrl}>
  <Header locale={locale} messages={messages} />
  <main>
    <Hero locale={locale} messages={messages} />
    <TrustSignals locale={locale} messages={messages} />
    <Services locale={locale} messages={messages} />
    <WhyKm0 locale={locale} messages={messages} />
    <CloudUserStats locale={locale} messages={messages} variant="band" />
    <Faq messages={messages} />
    <Community locale={locale} messages={messages} />
    <Contact messages={messages} />
    <Purpose messages={messages} />
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

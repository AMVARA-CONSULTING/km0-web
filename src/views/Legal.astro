---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const l = messages.legal;

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/legal/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={l.metaTitle}
  pageDescription={l.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="page-shell">
    <div class="section-pad !pt-10 md:!pt-14">
      <article class="page-inner !px-0">
        <header class="page-masthead" data-reveal>
          <p class="doc-kicker">{l.eyebrow}</p>
          <h1 class="heading-page text-ink">{l.heading}</h1>
          <p class="doc-index-intro">{l.intro}</p>
          <p class="page-meta">{l.updated}</p>
        </header>

        <nav class="page-toc" aria-label={l.tocTitle} data-reveal data-delay="60">
          <p class="page-toc-title">{l.tocTitle}</p>
          <ol class="page-toc-list">
            {
              l.sections.map((section) => (
                <li>
                  <a href={`#${section.id}`}>{section.title}</a>
                </li>
              ))
            }
          </ol>
        </nav>

        <div class="doc-body" data-reveal data-delay="100">
          {
            l.sections.map((section) => (
              <section id={section.id} class="doc-block scroll-mt-28">
                <h2 class="doc-block-title">{section.title}</h2>
                <div set:html={section.bodyHtml} />
              </section>
            ))
          }
        </div>
      </article>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

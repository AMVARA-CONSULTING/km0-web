---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const p = messages.presentation;

const pdfUrl = '/presentations/km0-digital-tecnologica-kilometro-cero.pdf';

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/presentation/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={p.metaTitle}
  pageDescription={p.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="page-shell presentation-main">
    <article class="presentation-page">
      <header class="presentation-hero km0-motif km0-motif--origin">
        <div class="presentation-hero-inner" data-reveal>
          <div class="presentation-hero-copy page-masthead presentation-masthead">
            <p class="doc-kicker">{p.eyebrow}</p>
            <h1 class="heading-page text-ink">{p.title}</h1>
            <p class="doc-index-intro">{p.lead}</p>
            <div class="page-closer__actions presentation-download-wrap">
              <a
                href="https://cloud.km0digital.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                {messages.hero.ctaPrimary}
              </a>
              <a href={pdfUrl} download class="page-closer__secondary">
                {p.download}
              </a>
            </div>
            <p class="page-meta presentation-download-hint">{p.downloadHint}</p>
          </div>
          <figure class="presentation-logo" data-reveal data-delay="100">
            <img
              src="/brand/logo.svg"
              alt={messages.hero.logoAlt}
              width="512"
              height="512"
              loading="eager"
              decoding="async"
            />
          </figure>
        </div>
      </header>

      <section class="presentation-section" aria-labelledby="presentation-why">
        <div class="presentation-container" data-reveal>
          <h2 id="presentation-why" class="heading-section text-ink">{p.why.title}</h2>
          <p class="presentation-prose">{p.why.body}</p>
        </div>
      </section>

      <section class="presentation-section surface-snow surface-band" aria-labelledby="presentation-compare">
        <div class="presentation-container" data-reveal>
          <h2 id="presentation-compare" class="heading-section text-ink">{p.compare.title}</h2>
          <div class="presentation-table-wrap">
            <table class="presentation-table">
              <thead>
                <tr>
                  <th scope="col">{p.compare.usualTitle}</th>
                  <th scope="col">{p.compare.km0Title}</th>
                </tr>
              </thead>
              <tbody>
                {
                  p.compare.rows.map((row) => (
                    <tr>
                      <td>{row.usual}</td>
                      <td>{row.km0}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="presentation-section" aria-labelledby="presentation-community">
        <div class="presentation-container presentation-split" data-reveal>
          <div class="presentation-split-copy">
            <h2 id="presentation-community" class="heading-section text-ink">{p.community.title}</h2>
            <h3 class="presentation-subhead">{p.community.subtitle}</h3>
            <p class="presentation-prose">{p.community.body}</p>
          </div>
          <figure class="presentation-figure">
            <img
              src="/presentations/assets/community-photo.png"
              alt={p.community.imageAlt}
              width="1024"
              height="684"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
      </section>

      <section class="presentation-section" aria-labelledby="presentation-cloud">
        <div class="presentation-container presentation-split presentation-split-reverse" data-reveal>
          <div class="presentation-split-copy">
            <h2 id="presentation-cloud" class="heading-section text-ink">{p.cloud.title}</h2>
            <p class="presentation-prose">{p.cloud.lead}</p>
            <ul class="presentation-list">
              {p.cloud.features.map((feature) => <li>{feature}</li>)}
            </ul>
          </div>
          <figure class="presentation-figure">
            <img
              src="/presentations/assets/cloud-interface.png"
              alt={p.cloud.imageAlt}
              width="1024"
              height="695"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
      </section>

      <section class="presentation-section" aria-labelledby="presentation-values">
        <div class="presentation-container" data-reveal>
          <h2 id="presentation-values" class="heading-section text-ink">{p.values.title}</h2>
          <ul class="presentation-ops-list">
            {
              p.values.items.map((item) => (
                <li class="presentation-ops-item">
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="presentation-section" aria-labelledby="presentation-privacy">
        <div class="presentation-container" data-reveal>
          <h2 id="presentation-privacy" class="heading-section text-ink">{p.privacy.title}</h2>
          <p class="presentation-prose">{p.privacy.lead}</p>
          <p class="presentation-highlight">{p.privacy.highlight}</p>
        </div>
      </section>

      <section class="presentation-section" aria-labelledby="presentation-security">
        <div class="presentation-container" data-reveal>
          <h2 id="presentation-security" class="heading-section text-ink">{p.security.title}</h2>
          <ol class="presentation-ops-list presentation-ops-list--numbered">
            {
              p.security.items.map((item) => (
                <li class="presentation-ops-item">
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section class="presentation-section" aria-labelledby="presentation-roadmap">
        <div class="presentation-container" data-reveal>
          <h2 id="presentation-roadmap" class="heading-section text-ink">{p.roadmap.title}</h2>
          <ol class="presentation-ops-list presentation-ops-list--numbered">
            {
              p.roadmap.steps.map((step) => (
                <li class="presentation-ops-item">
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section
        class="page-closer presentation-section surface-snow surface-band"
        aria-labelledby="presentation-cta"
      >
        <div class="presentation-container" data-reveal>
          <h2 id="presentation-cta" class="heading-section text-ink">{p.cta.title}</h2>
          <p class="presentation-prose">{p.cta.lead}</p>
          <div class="page-closer__actions">
            <a
              href="https://cloud.km0digital.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              {messages.hero.ctaPrimary}
            </a>
            <a href={pdfUrl} download class="page-closer__secondary">
              {p.download}
            </a>
          </div>
          <ul class="presentation-links">
            <li>
              <a href={localeHref(locale, '/')}>{p.cta.website}</a>
            </li>
            <li>
              <span>{p.cta.email}</span>
            </li>
          </ul>
          <p class="presentation-download-hint">{p.downloadHint}</p>
        </div>
      </section>
    </article>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

<style>
  .presentation-page {
    color: var(--color-ink);
  }

  .presentation-container {
    width: min(100%, 64rem);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 4vw, 3rem);
  }

  .presentation-hero {
    padding: clamp(2.5rem, 6vw, 4rem) 0 clamp(3rem, 7vw, 4.5rem);
    border-bottom: 1px solid var(--color-mist);
  }

  .presentation-hero-inner {
    width: min(100%, 64rem);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    display: grid;
    gap: clamp(1.75rem, 4vw, 3rem);
    align-items: center;
  }

  @media (min-width: 768px) {
    .presentation-hero-inner {
      grid-template-columns: minmax(0, 1.2fr) minmax(8rem, 12rem);
    }
  }

  .presentation-logo {
    margin: 0;
    justify-self: start;
  }

  @media (min-width: 768px) {
    .presentation-logo {
      justify-self: end;
    }
  }

  .presentation-logo img {
    display: block;
    width: min(100%, 11rem);
    height: auto;
    object-fit: contain;
  }

  .presentation-download-wrap {
    margin-top: 0.25rem;
  }

  .presentation-masthead {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: 0;
  }

  .presentation-download-hint {
    margin-top: 0.75rem;
  }

  .presentation-masthead .heading-page {
    max-width: 16ch;
  }

  .presentation-section {
    padding: var(--space-section-y) 0;
  }

  .presentation-subhead {
    margin: 0.75rem 0;
    font-family: theme('fontFamily.sans');
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .presentation-prose {
    margin: 0;
    max-width: 48rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
  }

  .presentation-table-wrap {
    overflow-x: auto;
    margin-top: 1.5rem;
    border: 1px solid var(--color-mist);
    background: var(--color-snow);
  }

  .presentation-table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
  }

  .presentation-table th,
  .presentation-table td {
    padding: 1rem 1.125rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--color-mist);
  }

  .presentation-table thead th {
    background: var(--color-ink);
    color: var(--color-snow);
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 600;
  }

  .presentation-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .presentation-table tbody td:first-child {
    color: var(--color-ink-muted);
  }

  .presentation-table tbody td:last-child {
    color: var(--color-ink);
    font-weight: 500;
  }

  .presentation-split {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: center;
  }

  @media (min-width: 900px) {
    .presentation-split {
      grid-template-columns: 1fr 1fr;
    }

    .presentation-split-reverse .presentation-split-copy {
      order: 2;
    }

    .presentation-split-reverse .presentation-figure {
      order: 1;
    }
  }

  .presentation-figure {
    margin: 0;
  }

  .presentation-figure img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--color-mist);
  }

  .presentation-list {
    margin: 1.25rem 0 0;
    padding-left: 1.25rem;
    max-width: 42rem;
    color: var(--color-ink-muted);
  }

  .presentation-list li + li {
    margin-top: 0.65rem;
  }

  .presentation-list li {
    line-height: 1.65;
  }

  .presentation-ops-list {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0;
  }

  .presentation-ops-list--numbered {
    list-style: none;
    counter-reset: presentation-step;
  }

  .presentation-ops-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-mist);
  }

  .presentation-ops-item:first-child {
    padding-top: 0;
  }

  .presentation-ops-item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .presentation-ops-list--numbered .presentation-ops-item {
    counter-increment: presentation-step;
  }

  .presentation-ops-item h3 {
    margin: 0 0 0.35rem;
    font-family: theme('fontFamily.display');
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .presentation-ops-list--numbered .presentation-ops-item h3::before {
    content: counter(presentation-step) '. ';
    color: var(--color-signal);
  }

  .presentation-ops-item p {
    margin: 0;
    max-width: 60ch;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }

  .presentation-highlight {
    margin: 1.25rem 0 0;
    font-family: theme('fontFamily.sans');
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-signal);
  }

  .presentation-links {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .presentation-links a {
    color: var(--color-ink);
    font-family: theme('fontFamily.sans');
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .presentation-links a:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 3px;
  }
</style>

---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const p = messages.pricing;

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/pricing/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={p.metaTitle}
  pageDescription={p.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="page-shell pricing-page">
    <section class="pricing-section" aria-labelledby="pricing-heading">
      <div class="page-inner--wide">
        <header class="page-masthead pricing-masthead">
          <div class="pricing-masthead-copy">
            <p class="doc-kicker">{p.eyebrow}</p>
            <h1 id="pricing-heading" class="heading-section text-ink">{p.heading}</h1>
            <p class="doc-index-intro">{p.intro}</p>
            <div class="pricing-hero-cta">
              <a
                href="https://cloud.km0digital.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                {p.heroCta}
              </a>
            </div>
          </div>
          <div class="pricing-hero-stat" aria-label={p.heroPrice.ariaLabel}>
            <p class="pricing-hero-capacity tabular-nums">
              <span class="pricing-hero-capacity-value">{p.heroPrice.meta}</span>
            </p>
            <p class="pricing-hero-price tabular-nums">
              <span class="pricing-hero-price-value">{p.heroPrice.amount}</span><span
                class="pricing-hero-price-period">{p.heroPrice.period}</span
              >
            </p>
          </div>
        </header>
      </div>
    </section>

    <section class="pricing-section page-band" aria-labelledby="pricing-compare">
      <div class="page-inner--wide">
        <header class="pricing-section-header">
          <h2 id="pricing-compare" class="pricing-compare-heading text-ink">
            {p.compareHeading}
          </h2>
          <p class="doc-index-intro">{p.compareIntro}</p>
        </header>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th scope="col">{p.table.provider}</th>
                <th scope="col">{p.table.monthlyPrice}</th>
                <th scope="col">{p.table.storageGb}</th>
                <th scope="col">{p.table.costPerTbMonth}</th>
              </tr>
            </thead>
            <tbody>
              {
                p.rows.map((row) => (
                  <tr class:list={row.highlight && 'pricing-table-row-highlight'}>
                    <th scope="row">{row.provider}</th>
                    <td>{row.monthlyPrice}</td>
                    <td>{row.storageGb}</td>
                    <td>{row.costPerTbMonth}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="pricing-claim">{p.claim}</p>
        <p class="pricing-table-note">{p.tableDisclaimer}</p>
      </div>
    </section>

    <section class="pricing-section" aria-labelledby="pricing-why">
      <div class="page-inner--wide">
        <h2 id="pricing-why" class="heading-section mb-4 text-ink">{p.whyPricing.heading}</h2>
        <p class="doc-index-intro mt-0">{p.whyPricing.body}</p>
      </div>
    </section>

    <section class="pricing-section page-band" aria-labelledby="pricing-ops">
      <div class="page-inner--wide">
        <h2 id="pricing-ops" class="heading-section mb-8 text-ink">{p.trust.heading}</h2>
        <ul class="pricing-ops-list">
          {
            p.trust.items.map((item) => (
              <li class="pricing-ops-item">
                <h3 class="pricing-ops-title">{item.title}</h3>
                <p class="pricing-ops-desc">{item.desc}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="pricing-section" aria-labelledby="pricing-custom">
      <div class="page-inner--wide">
        <h2 id="pricing-custom" class="heading-section mb-4 text-ink">{p.custom.heading}</h2>
        <p class="doc-index-intro mt-0">{p.custom.body}</p>
        <div class="pricing-custom-cta">
          <a href={`mailto:${messages.contact.email}`} class="btn-primary">
            {p.custom.cta}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

<style>
  .pricing-section {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .pricing-masthead {
    display: grid;
    gap: clamp(2rem, 5vw, 3rem);
    align-items: end;
    margin-bottom: 0;
    border-bottom: 0;
    padding-bottom: 0;
  }

  @media (min-width: 900px) {
    .pricing-masthead {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    }
  }

  .pricing-masthead-copy {
    min-width: 0;
  }

  .pricing-hero-cta {
    margin-top: 1.75rem;
  }

  .pricing-hero-stat {
    justify-self: start;
  }

  @media (min-width: 900px) {
    .pricing-hero-stat {
      justify-self: end;
      text-align: right;
    }
  }

  .pricing-hero-capacity {
    margin: 0;
    line-height: 1;
  }

  .pricing-hero-capacity-value {
    font-family: theme('fontFamily.display');
    font-size: clamp(3.5rem, 10vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    color: var(--color-signal);
  }

  .pricing-hero-price {
    margin: 0.75rem 0 0;
    line-height: 1.2;
  }

  .pricing-hero-price-value {
    font-family: theme('fontFamily.sans');
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 600;
    color: var(--color-ink-muted);
  }

  .pricing-hero-price-period {
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    font-weight: 600;
    margin-left: 0.1em;
    color: var(--color-ink-muted);
  }

  .pricing-section-header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }

  .pricing-compare-heading {
    margin: 0;
    font-family: theme('fontFamily.display');
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .pricing-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-mist);
    background: var(--color-snow);
  }

  .pricing-table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
  }

  .pricing-table th,
  .pricing-table td {
    padding: 1rem 1.125rem;
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid var(--color-mist);
  }

  .pricing-table thead th {
    background: var(--color-ink);
    color: var(--color-snow);
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 600;
  }

  .pricing-table tbody tr:last-child th,
  .pricing-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .pricing-table tbody th {
    color: var(--color-ink);
    font-weight: 600;
  }

  .pricing-table tbody td {
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
  }

  .pricing-table-row-highlight {
    background: color-mix(in srgb, var(--color-signal) 8%, transparent);
  }

  .pricing-table-row-highlight th {
    color: var(--color-signal);
  }

  .pricing-claim {
    margin: 1.75rem 0 0;
    max-width: 60ch;
    font-family: theme('fontFamily.sans');
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.55;
    color: var(--color-signal);
  }

  .pricing-table-note {
    margin: 1rem 0 0;
    max-width: 60ch;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .pricing-ops-list {
    display: grid;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pricing-ops-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-mist);
  }

  .pricing-ops-item:first-child {
    padding-top: 0;
  }

  .pricing-ops-item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .pricing-ops-title {
    margin: 0 0 0.35rem;
    font-family: theme('fontFamily.display');
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .pricing-ops-desc {
    margin: 0;
    max-width: 60ch;
    font-size: 0.9875rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }

  .pricing-custom-cta {
    margin-top: 1.75rem;
  }
</style>

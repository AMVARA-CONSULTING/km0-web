---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, withHash } from '../i18n/paths';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const p = messages.pricing;

const pathHref = (cta: 'cloud' | 'email' | 'contact') => {
  if (cta === 'cloud') return 'https://cloud.km0digital.com/';
  if (cta === 'email') return 'https://mail.km0digital.com/';
  return withHash(locale, 'contact');
};

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/pricing/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={p.metaTitle}
  pageDescription={p.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="page-shell pricing-page">
    <section class="pricing-section" aria-labelledby="pricing-heading">
      <div class="page-inner--wide">
        <header class="page-masthead pricing-masthead" data-reveal>
          <div class="pricing-masthead-copy">
            <p class="doc-kicker">{p.eyebrow}</p>
            <h1 id="pricing-heading" class="heading-page text-ink">{p.heading}</h1>
            <p class="doc-index-intro">{p.intro}</p>
            <div class="page-closer__actions pricing-hero-cta">
              <a
                href="https://cloud.km0digital.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                {p.heroCta}
              </a>
            </div>
          </div>
          <div class="pricing-hero-stat" aria-label={p.heroPrice.ariaLabel} data-reveal data-delay="100">
            <p class="pricing-hero-capacity tabular-nums" aria-hidden="true">
              <span
                class="pricing-hero-capacity-value"
                data-pricing-capacity
                data-target={p.heroPrice.capacity}
              >{p.heroPrice.capacity}</span>
              <span class="pricing-hero-capacity-unit">{p.heroPrice.unit}</span>
            </p>
            <div class="pricing-hero-meter" role="presentation" aria-hidden="true">
              <span class="pricing-hero-meter-fill"></span>
            </div>
            <p class="pricing-hero-host-meta">{p.heroPrice.hostMeta}</p>
            <p class="pricing-hero-price tabular-nums">
              <span class="pricing-hero-price-value">{p.heroPrice.amount}</span><span
                class="pricing-hero-price-period">{p.heroPrice.period}</span
              >
            </p>
          </div>
        </header>
      </div>
    </section>

    <section class="pricing-section" aria-labelledby="pricing-paths">
      <div class="page-inner--wide" data-reveal>
        <header class="pricing-section-header">
          <h2 id="pricing-paths" class="pricing-band-heading text-ink">{p.pathsHeading}</h2>
          <p class="doc-index-intro pricing-band-intro">{p.pathsIntro}</p>
        </header>
        <div class="pricing-paths" role="list">
          {
            p.paths.map((path) => {
              const href = pathHref(path.cta);
              const external = path.cta === 'cloud' || path.cta === 'email';
              return (
                <article
                  class:list={['pricing-path', path.lead && 'pricing-path--lead']}
                  role="listitem"
                  data-reveal
                >
                  <p class="pricing-path__meta">{path.meta}</p>
                  <h3 class="pricing-path__title">{path.title}</h3>
                  <p class="pricing-path__price tabular-nums">
                    <span class="pricing-path__price-value">{path.price}</span>
                    <span class="pricing-path__price-note">{path.priceNote}</span>
                  </p>
                  <p class="pricing-path__body">{path.body}</p>
                  <ul class="pricing-path__features">
                    {path.features.map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                  <div class="pricing-path__cta">
                    {path.lead ? (
                      <a
                        href={href}
                        target={external ? '_blank' : undefined}
                        rel={external ? 'noopener noreferrer' : undefined}
                        class="btn-primary"
                      >
                        {path.ctaLabel}
                      </a>
                    ) : (
                      <a
                        href={href}
                        target={external ? '_blank' : undefined}
                        rel={external ? 'noopener noreferrer' : undefined}
                        class="page-closer__secondary"
                      >
                        {path.ctaLabel}
                      </a>
                    )}
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </section>

    <section class="pricing-section surface-snow surface-band" aria-labelledby="pricing-compare">
      <div class="page-inner--wide" data-reveal>
        <header class="pricing-section-header">
          <h2 id="pricing-compare" class="pricing-band-heading text-ink">
            {p.compareHeading}
          </h2>
          <p class="doc-index-intro pricing-band-intro">{p.compareIntro}</p>
        </header>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th scope="col">{p.table.provider}</th>
                <th scope="col">{p.table.monthlyPrice}</th>
                <th scope="col">{p.table.storageGb}</th>
                <th scope="col">{p.table.costPerTbMonth}</th>
              </tr>
            </thead>
            <tbody>
              {
                p.rows.map((row) => (
                  <tr class:list={row.highlight && 'pricing-table-row-highlight'}>
                    <th scope="row">{row.provider}</th>
                    <td>{row.monthlyPrice}</td>
                    <td>{row.storageGb}</td>
                    <td>{row.costPerTbMonth}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="pricing-claim">{p.claim}</p>
        <p class="pricing-table-note">{p.tableDisclaimer}</p>
      </div>
    </section>

    <section class="pricing-section" aria-labelledby="pricing-why">
      <div class="page-inner--wide pricing-why-grid" data-reveal>
        <div>
          <h2 id="pricing-why" class="pricing-band-heading text-ink">{p.whyPricing.heading}</h2>
          <p class="doc-index-intro pricing-band-intro">{p.whyPricing.body}</p>
        </div>
        <div aria-labelledby="pricing-ops">
          <h2 id="pricing-ops" class="pricing-band-heading text-ink">{p.trust.heading}</h2>
          <ul class="pricing-ops-list">
            {
              p.trust.items.map((item) => (
                <li class="pricing-ops-item">
                  <h3 class="pricing-ops-title">{item.title}</h3>
                  <p class="pricing-ops-desc">{item.desc}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section
      class="page-closer pricing-section surface-snow surface-band"
      aria-labelledby="pricing-custom"
    >
      <div class="page-inner--wide" data-reveal>
        <h2 id="pricing-custom" class="pricing-band-heading text-ink">{p.custom.heading}</h2>
        <p class="doc-index-intro pricing-band-intro">{p.custom.body}</p>
        <div class="page-closer__actions">
          <a
            href="https://cloud.km0digital.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            {p.heroCta}
          </a>
          <a href={withHash(locale, 'contact')} class="page-closer__secondary">
            {p.custom.cta}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

<style>
  .pricing-section {
    padding-block: var(--space-section-y);
  }

  .pricing-masthead {
    display: grid;
    gap: clamp(2rem, 5vw, 3rem);
    align-items: end;
    margin-bottom: 0;
    border-bottom: 0;
    padding-bottom: 0;
  }

  @media (min-width: 900px) {
    .pricing-masthead {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    }
  }

  .pricing-masthead-copy {
    min-width: 0;
  }

  .pricing-masthead-copy .heading-page {
    max-width: 12ch;
  }

  .pricing-hero-cta {
    margin-top: 0.25rem;
  }

  .pricing-hero-stat {
    justify-self: start;
    display: grid;
    gap: 0.55rem;
    justify-items: start;
    max-width: 16rem;
  }

  @media (min-width: 900px) {
    .pricing-hero-stat {
      justify-self: end;
      justify-items: end;
      text-align: right;
    }
  }

  .pricing-hero-capacity {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.2em;
    line-height: 1;
    color: var(--color-ink);
    opacity: 0;
    transform: translate3d(0, 0.4rem, 0);
  }

  .pricing-hero-capacity-value {
    font-family: theme('fontFamily.display');
    font-variant-numeric: tabular-nums;
    font-size: clamp(4rem, 12vw, 6.25rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    color: var(--color-ink);
  }

  .pricing-hero-capacity-unit {
    font-family: theme('fontFamily.display');
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--color-signal);
  }

  .pricing-hero-stat.is-visible .pricing-hero-capacity {
    animation: pricing-capacity-in var(--duration-hero-capacity) var(--ease-out-expo) both;
  }

  .pricing-hero-meter {
    width: min(100%, 11rem);
    height: 0.45rem;
    background: var(--color-mist);
    overflow: hidden;
  }

  .pricing-hero-meter-fill {
    display: block;
    height: 100%;
    width: calc(var(--hero-meter-fill) * 100%);
    background: var(--color-signal);
    transform: scaleX(0);
    transform-origin: left center;
  }

  @media (min-width: 900px) {
    .pricing-hero-meter-fill {
      transform-origin: right center;
    }
  }

  .pricing-hero-stat.is-visible .pricing-hero-meter-fill {
    animation: pricing-meter var(--duration-hero-capacity) var(--ease-out-expo) 70ms both;
  }

  .pricing-hero-host-meta {
    margin: 0;
    font-family: theme('fontFamily.sans');
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    opacity: 0;
    transform: translate3d(0, 0.25rem, 0);
  }

  .pricing-hero-stat.is-visible .pricing-hero-host-meta {
    animation: pricing-capacity-in var(--duration-hero-capacity) var(--ease-out-expo) 60ms both;
  }

  .pricing-hero-price {
    margin: 0.2rem 0 0;
    line-height: 1.2;
  }

  .pricing-hero-price-value {
    font-family: theme('fontFamily.sans');
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 600;
    color: var(--color-ink-muted);
  }

  .pricing-hero-price-period {
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    font-weight: 600;
    margin-left: 0.1em;
    color: var(--color-ink-muted);
  }

  @keyframes pricing-capacity-in {
    from {
      opacity: 0;
      transform: translate3d(0, 0.4rem, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes pricing-meter {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-hero-capacity,
    .pricing-hero-host-meta {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .pricing-hero-meter-fill {
      transform: scaleX(1);
      animation: none;
    }
  }

  .pricing-section-header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }

  .pricing-band-heading {
    margin: 0;
    font-family: theme('fontFamily.display');
    font-size: clamp(1.45rem, 3.2vw, 1.9rem);
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  .pricing-band-intro {
    margin-top: 0;
  }

  /* Editorial plan paths - Cloud lead, not equal icon cards */
  .pricing-paths {
    display: grid;
    gap: 0;
    border-block: 1px solid var(--color-mist);
  }

  @media (min-width: 960px) {
    .pricing-paths {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.9fr) minmax(0, 0.9fr);
      border-inline: 1px solid var(--color-mist);
      border-block: 1px solid var(--color-mist);
    }
  }

  .pricing-path {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-bottom: 1px solid var(--color-mist);
    background: transparent;
  }

  .pricing-path:last-child {
    border-bottom: 0;
  }

  @media (min-width: 960px) {
    .pricing-path {
      border-bottom: 0;
      border-right: 1px solid var(--color-mist);
      min-height: 100%;
    }

    .pricing-path:last-child {
      border-right: 0;
    }
  }

  .pricing-path--lead {
    background: var(--surface-snow);
  }

  .pricing-path__meta {
    margin: 0;
    font-family: theme('fontFamily.sans');
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .pricing-path--lead .pricing-path__meta {
    color: var(--color-signal);
  }

  .pricing-path__title {
    margin: 0;
    font-family: theme('fontFamily.display');
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .pricing-path__price {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.5rem;
  }

  .pricing-path__price-value {
    font-family: theme('fontFamily.display');
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .pricing-path--lead .pricing-path__price-value {
    color: var(--color-signal);
  }

  .pricing-path__price-note {
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-muted);
  }

  .pricing-path__body {
    margin: 0;
    max-width: 36ch;
    font-size: 0.9875rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .pricing-path__features {
    margin: 0.25rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.55rem;
    flex: 1;
  }

  .pricing-path__features li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink);
  }

  .pricing-path__features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.35rem;
    height: 0.35rem;
    background: var(--color-signal);
  }

  .pricing-path__cta {
    margin-top: 0.75rem;
  }

  .pricing-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-mist);
    background: var(--surface-paper);
  }

  .pricing-table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
  }

  .pricing-table th,
  .pricing-table td {
    padding: 1rem 1.125rem;
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid var(--color-mist);
  }

  .pricing-table thead th {
    background: var(--surface-ink);
    color: var(--color-on-ink);
    font-family: theme('fontFamily.sans');
    font-size: 0.875rem;
    font-weight: 600;
  }

  .pricing-table tbody tr:last-child th,
  .pricing-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .pricing-table tbody th {
    color: var(--color-ink);
    font-weight: 600;
  }

  .pricing-table tbody td {
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
  }

  .pricing-table-row-highlight {
    background: color-mix(in srgb, var(--color-signal) 10%, transparent);
  }

  .pricing-table-row-highlight th {
    color: var(--color-signal);
  }

  .pricing-claim {
    margin: 1.75rem 0 0;
    max-width: 60ch;
    font-family: theme('fontFamily.sans');
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.55;
    color: var(--color-signal);
  }

  .pricing-table-note {
    margin: 1rem 0 0;
    max-width: 60ch;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .pricing-why-grid {
    display: grid;
    gap: clamp(2.5rem, 5vw, 3.5rem);
  }

  @media (min-width: 900px) {
    .pricing-why-grid {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      align-items: start;
    }
  }

  .pricing-ops-list {
    display: grid;
    gap: 0;
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .pricing-ops-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-mist);
  }

  .pricing-ops-item:first-child {
    padding-top: 0;
  }

  .pricing-ops-item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .pricing-ops-title {
    margin: 0 0 0.35rem;
    font-family: theme('fontFamily.display');
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .pricing-ops-desc {
    margin: 0;
    max-width: 60ch;
    font-size: 0.9875rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
  }
</style>

<script>
  import '../scripts/hero-capacity.ts';
</script>

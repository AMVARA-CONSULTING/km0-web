---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const p = messages.pricing;

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/pricing/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={p.metaTitle}
  pageDescription={p.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="pricing-page pt-28">
    <section class="pricing-section pricing-section--hero bg-white" aria-labelledby="pricing-heading">
      <div class="pricing-inner">
        <header class="pricing-hero-header text-center">
          <p class="doc-eyebrow">{p.eyebrow}</p>
          <h1 id="pricing-heading" class="heading-section text-navy">{p.heading}</h1>
          <div class="pricing-hero-stat" aria-label={p.heroPrice.ariaLabel}>
            <p class="pricing-hero-capacity tabular-nums">
              <span class="pricing-hero-capacity-value pricing-hero-capacity-gradient">{p.heroPrice.meta}</span>
            </p>
            <p class="pricing-hero-price tabular-nums">
              <span class="pricing-hero-price-value">{p.heroPrice.amount}</span><span
                class="pricing-hero-price-period">{p.heroPrice.period}</span
              >
            </p>
          </div>
          <p class="doc-index-intro mx-auto max-w-3xl">{p.intro}</p>
          <div class="pricing-hero-cta">
            <a
              href="https://cloud.km0digital.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              {p.heroCta}
            </a>
          </div>
        </header>
      </div>
    </section>

    <section class="pricing-section pricing-section--surface" aria-labelledby="pricing-compare">
      <div class="pricing-inner">
        <header class="pricing-section-header text-center">
          <h2 id="pricing-compare" class="pricing-compare-heading text-navy">
            {p.compareHeading}
          </h2>
          <p class="doc-index-intro mx-auto max-w-3xl">{p.compareIntro}</p>
        </header>
        <div class="pricing-table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th scope="col">{p.table.provider}</th>
                <th scope="col">{p.table.monthlyPrice}</th>
                <th scope="col">{p.table.storageGb}</th>
                <th scope="col">{p.table.costPerTbMonth}</th>
              </tr>
            </thead>
            <tbody>
              {
                p.rows.map((row) => (
                  <tr class:list={row.highlight && 'pricing-table-row-highlight'}>
                    <th scope="row">{row.provider}</th>
                    <td>{row.monthlyPrice}</td>
                    <td>{row.storageGb}</td>
                    <td>{row.costPerTbMonth}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="pricing-claim mx-auto max-w-3xl text-center">{p.claim}</p>
        <p class="pricing-table-note">{p.tableDisclaimer}</p>
      </div>
    </section>

    <section class="pricing-section bg-white" aria-labelledby="pricing-why">
      <div class="pricing-inner">
        <div class="pricing-why">
          <h2 id="pricing-why" class="heading-section mb-6 text-center text-navy">
            {p.whyPricing.heading}
          </h2>
          <p class="doc-index-intro mx-auto max-w-3xl text-center">{p.whyPricing.body}</p>
        </div>
      </div>
    </section>

    <section class="pricing-section pricing-section--surface" aria-labelledby="pricing-trust">
      <div class="pricing-inner">
        <header class="pricing-section-header text-center">
          <h2 id="pricing-trust" class="heading-section text-navy">
            {p.trust.heading}
          </h2>
        </header>
        <ul class="pricing-trust-grid">
          {
            p.trust.items.map((item) => (
              <li class="pricing-trust-card">
                <h3 class="pricing-trust-title">{item.title}</h3>
                <p class="pricing-trust-desc">{item.desc}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="pricing-section bg-white" aria-labelledby="pricing-diff">
      <div class="pricing-inner">
        <header class="pricing-section-header text-center">
          <h2 id="pricing-diff" class="heading-section text-navy">
            {p.differentiators.heading}
          </h2>
        </header>
        <ul class="pricing-diff-list">
          {
            p.differentiators.items.map((item) => (
              <li class="pricing-diff-item">{item}</li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="pricing-section pricing-section--cta bg-surface" aria-labelledby="pricing-custom">
      <div class="pricing-inner">
        <header class="pricing-section-header text-center">
          <h2 id="pricing-custom" class="heading-section text-navy">
            {p.custom.heading}
          </h2>
          <p class="doc-index-intro mx-auto max-w-2xl">{p.custom.body}</p>
        </header>
        <div class="pricing-custom-cta text-center">
          <a href={`mailto:${messages.contact.email}`} class="btn-primary">
            {p.custom.cta}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

<style>
  .pricing-page {
    background: #fff;
  }

  .pricing-inner {
    width: 100%;
    max-width: 64rem;
    margin-inline: auto;
  }

  .pricing-section {
    padding: clamp(3.5rem, 8vw, 5.5rem) clamp(1.5rem, 5vw, 5rem);
  }

  .pricing-section--hero {
    padding-bottom: clamp(4rem, 9vw, 6rem);
  }

  .pricing-section--surface {
    background: rgb(248 250 252);
    border-block: 1px solid rgb(15 23 42 / 0.06);
  }

  .pricing-section--cta {
    border-top: 1px solid rgb(15 23 42 / 0.08);
  }

  .pricing-section-header {
    display: grid;
    gap: 1.25rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }

  .pricing-hero-header {
    display: grid;
    gap: clamp(1rem, 3vw, 1.5rem);
  }

  .pricing-hero-stat {
    margin: clamp(0.5rem, 2vw, 1rem) auto 0;
  }

  .pricing-hero-cta {
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .pricing-hero-capacity {
    display: flex;
    flex-wrap: nowrap;
    align-items: baseline;
    justify-content: center;
    margin: 0;
    line-height: 1;
    white-space: nowrap;
  }

  .pricing-hero-capacity-value {
    font-size: clamp(4rem, 14vw, 7rem);
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .pricing-hero-capacity-gradient {
    color: #0f766e;
  }

  .pricing-hero-price {
    display: flex;
    flex-wrap: nowrap;
    align-items: baseline;
    justify-content: center;
    margin: 1.125rem 0 0;
    line-height: 1.2;
    white-space: nowrap;
  }

  .pricing-hero-price-value {
    font-size: clamp(1.125rem, 3vw, 1.375rem);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: rgb(15 23 42 / 0.62);
  }

  .pricing-hero-price-period {
    flex-shrink: 0;
    font-size: clamp(0.9375rem, 2.5vw, 1.125rem);
    font-weight: 600;
    letter-spacing: 0.01em;
    margin-left: 0.1em;
    color: rgb(15 23 42 / 0.55);
  }

  .pricing-claim {
    margin: clamp(2rem, 5vw, 3rem) auto 0;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.6;
    color: #0f766e;
  }

  .pricing-compare-heading {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .pricing-compare-heading {
      font-size: 1.5rem;
    }
  }

  .pricing-table-wrap {
    overflow-x: auto;
    border: 1px solid rgb(15 23 42 / 0.08);
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 8px 24px rgb(15 23 42 / 0.05);
  }

  .pricing-table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
  }

  .pricing-table th,
  .pricing-table td {
    padding: 1.125rem 1.25rem;
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid rgb(15 23 42 / 0.08);
  }

  .pricing-table thead th {
    background: #0b1220;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .pricing-table thead th:first-child {
    border-top-left-radius: 0.95rem;
  }

  .pricing-table thead th:last-child {
    border-top-right-radius: 0.95rem;
  }

  .pricing-table tbody tr:last-child th,
  .pricing-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .pricing-table tbody th {
    color: #0f172a;
    font-weight: 600;
  }

  .pricing-table tbody td {
    color: #334155;
    font-variant-numeric: tabular-nums;
  }

  .pricing-table-row-highlight {
    background: rgb(15 118 110 / 0.06);
  }

  .pricing-table-row-highlight th {
    color: #0f766e;
  }

  .pricing-table-note {
    margin: 1.5rem 0 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgb(15 23 42 / 0.55);
    text-align: center;
  }

  .pricing-why {
    padding: clamp(2.25rem, 5vw, 3.5rem);
    border-radius: 1.25rem;
    background: rgb(248 250 252);
    border: 1px solid rgb(15 23 42 / 0.08);
  }

  .pricing-trust-grid {
    display: grid;
    gap: clamp(1.25rem, 3vw, 1.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }

  .pricing-trust-card {
    padding: 1.5rem 1.625rem;
    border-radius: 1rem;
    border: 1px solid rgb(15 23 42 / 0.08);
    background: #fff;
    box-shadow: 0 4px 16px rgb(15 23 42 / 0.04);
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .pricing-trust-card:hover {
    border-color: rgb(15 23 42 / 0.14);
    box-shadow: 0 8px 24px rgb(15 23 42 / 0.08);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-trust-card {
      transition: border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .pricing-trust-card:hover {
      transform: none;
    }
  }

  .pricing-trust-title {
    margin: 0 0 0.625rem;
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
  }

  .pricing-trust-desc {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgb(15 23 42 / 0.7);
  }

  .pricing-diff-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pricing-diff-item {
    padding: 0.75rem 1.375rem;
    border-radius: 9999px;
    background: rgb(15 118 110 / 0.08);
    border: 1px solid rgb(15 118 110 / 0.18);
    font-size: 0.9375rem;
    font-weight: 500;
    color: #0f766e;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .pricing-diff-item:hover {
    background: rgb(15 118 110 / 0.14);
    border-color: rgb(15 118 110 / 0.28);
    box-shadow: 0 6px 18px rgb(15 118 110 / 0.12);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-diff-item {
      transition: background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .pricing-diff-item:hover {
      transform: none;
    }
  }

  .pricing-custom-cta {
    margin-top: clamp(2rem, 5vw, 2.75rem);
  }
</style>

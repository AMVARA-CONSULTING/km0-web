---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const s = messages.security;

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/security/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={s.metaTitle}
  pageDescription={s.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="page-shell">
    <div class="section-pad !pt-10 md:!pt-14">
      <article class="page-inner !px-0">
        <header class="page-masthead">
          <p class="doc-kicker">{s.eyebrow}</p>
          <h1 class="heading-section text-ink">{s.heading}</h1>
          <p class="doc-index-intro">{s.intro}</p>
          <p class="mt-4 font-sans text-sm text-ink/50">{s.updated}</p>
        </header>

        <nav class="page-toc" aria-label={s.tocTitle}>
          <p class="page-toc-title">{s.tocTitle}</p>
          <ol class="page-toc-list">
            {
              s.sections.map((section) => (
                <li>
                  <a href={`#${section.id}`}>{section.title}</a>
                </li>
              ))
            }
          </ol>
        </nav>

        <div class="doc-body">
          {
            s.sections.map((section) => (
              <section id={section.id} class="doc-block scroll-mt-28">
                <h2 class="doc-block-title">{section.title}</h2>
                <div set:html={section.bodyHtml} />
              </section>
            ))
          }
        </div>
      </article>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

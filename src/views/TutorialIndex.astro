---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, tutorialPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import { getCollection } from 'astro:content';
import { tutorialSlug, compareTutorials } from '../lib/tutorial';
import { estimateReadingMinutes, formatReadingTime } from '../lib/reading';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const tutorials = (await getCollection('tutorials', ({ data }) => data.locale === locale)).sort(
  compareTutorials,
);

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const canonicalUrl = new URL(localeHref(locale, '/tutorials/'), siteRoot).href;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={messages.tutorials.metaTitle}
  pageDescription={messages.tutorials.metaDescription}
>
  <Header locale={locale} messages={messages} />
  <main class="reading-page">
    <div class="reading-index">
      <header class="reading-index-masthead">
        <p class="reading-index-label">{messages.tutorials.eyebrow}</p>
        <h1 class="reading-index-title">{messages.tutorials.heading}</h1>
        <p class="reading-index-dek">{messages.tutorials.intro}</p>
      </header>

      <ul class="reading-catalog">
        {
          tutorials.map((tutorial, index) => {
            const readingMinutes = estimateReadingMinutes(tutorial.body ?? '', locale);
            const readingTime = formatReadingTime(messages.tutorials.readingTime, readingMinutes);

            return (
              <li class:list={['reading-entry', index === 0 && 'reading-entry--feature']}>
                <h2 class="reading-entry-title">
                  <a href={tutorialPostHref(locale, tutorialSlug(tutorial))}>
                    {tutorial.data.title}
                  </a>
                </h2>
                <p class="reading-entry-dek">{tutorial.data.description}</p>
                <div class="reading-entry-meta">
                  <span class="reading-platform">{tutorial.data.platform}</span>
                  <span>{readingTime}</span>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

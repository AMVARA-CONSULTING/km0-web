---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import DocArticleChrome from '../components/DocArticleChrome.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, tutorialPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { tutorialSlug, compareTutorials } from '../lib/tutorial';
import {
  extractDocToc,
  estimateReadingMinutes,
  tocFromMarkdownHeadings,
} from '../lib/reading';

interface Props {
  locale: Locale;
  tutorial: CollectionEntry<'tutorials'>;
}

const { locale, tutorial } = Astro.props;
const messages = getMessages(locale);
const { Content, headings } = await tutorial.render();

const tutorials = (await getCollection('tutorials', ({ data }) => data.locale === locale)).sort(
  compareTutorials,
);
const tutorialIndex = tutorials.findIndex((entry) => entry.id === tutorial.id);
const previousTutorial = tutorialIndex > 0 ? tutorials[tutorialIndex - 1] : undefined;
const nextTutorial =
  tutorialIndex >= 0 && tutorialIndex < tutorials.length - 1
    ? tutorials[tutorialIndex + 1]
    : undefined;
const relatedTutorials = tutorials.filter((entry) => entry.id !== tutorial.id).slice(0, 2);

const mdToc = tocFromMarkdownHeadings(headings);
const toc = mdToc.length > 0 ? mdToc : extractDocToc(tutorial.body ?? '');
const readingMinutes = estimateReadingMinutes(tutorial.body ?? '', locale);

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const tutorialPath = tutorialPostHref(locale, tutorialSlug(tutorial));
const canonicalUrl = new URL(tutorialPath, siteRoot).href;
const pageTitle = `${tutorial.data.title} - ${messages.brandNameShort}`;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={pageTitle}
  pageDescription={tutorial.data.description}
>
  <Header locale={locale} messages={messages} />
  <main class="reading-page">
    <DocArticleChrome
      breadcrumbHome={messages.tutorials.breadcrumbHome}
      breadcrumbHomeHref={localeHref(locale, '/tutorials/')}
      title={tutorial.data.title}
      description={tutorial.data.description}
      readingTimeLabel={messages.tutorials.readingTime}
      readingMinutes={readingMinutes}
      tocTitle={messages.tutorials.tocTitle}
      toc={toc}
      prevLabel={messages.tutorials.previousTutorial}
      nextLabel={messages.tutorials.nextTutorial}
      backHref={localeHref(locale, '/tutorials/')}
      backLabel={messages.tutorials.backToIndex}
      relatedTitle={messages.tutorials.relatedTutorials}
      platformLabel={tutorial.data.platform}
      prev={
        previousTutorial
          ? {
              href: tutorialPostHref(locale, tutorialSlug(previousTutorial)),
              title: previousTutorial.data.title,
            }
          : undefined
      }
      next={
        nextTutorial
          ? {
              href: tutorialPostHref(locale, tutorialSlug(nextTutorial)),
              title: nextTutorial.data.title,
            }
          : undefined
      }
      related={relatedTutorials.map((entry) => ({
        href: tutorialPostHref(locale, tutorialSlug(entry)),
        title: entry.data.title,
        description: entry.data.description,
      }))}
    >
      <Content />
    </DocArticleChrome>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>

---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import { getMessages } from '../i18n';
import { localeHref, tutorialPostHref } from '../i18n/paths';
import type { Locale } from '../i18n/types';
import type { CollectionEntry } from 'astro:content';
import { tutorialSlug } from '../lib/tutorial';

interface Props {
  locale: Locale;
  tutorial: CollectionEntry<'tutorials'>;
}

const { locale, tutorial } = Astro.props;
const messages = getMessages(locale);
const { Content } = await tutorial.render();

const siteRoot = Astro.site ?? new URL('https://km0digital.com');
const tutorialPath = tutorialPostHref(locale, tutorialSlug(tutorial));
const canonicalUrl = new URL(tutorialPath, siteRoot).href;
const pageTitle = `${tutorial.data.title} - ${messages.brandNameShort}`;
---

<Layout
  locale={locale}
  messages={messages}
  canonicalUrl={canonicalUrl}
  pageTitle={pageTitle}
  pageDescription={tutorial.data.description}
>
  <Header locale={locale} messages={messages} />
  <main class="section-pad bg-white pt-28">
    <article class="doc-article mx-auto max-w-4xl">
      <nav class="doc-breadcrumb mb-10" aria-label="Breadcrumb">
        <a href={localeHref(locale, '/tutorials/')} class="doc-breadcrumb-link">
          {messages.tutorials.breadcrumbHome}
        </a>
        <span class="doc-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="doc-breadcrumb-current">{tutorial.data.title}</span>
      </nav>

      <header class="doc-header mb-12">
        <h1 class="heading-section doc-title text-navy">{tutorial.data.title}</h1>
        <p class="doc-dek text-justify">{tutorial.data.description}</p>
      </header>

      <div class="doc-body">
        <Content />
      </div>

      <footer class="doc-footer">
        <a href={localeHref(locale, '/tutorials/')} class="doc-back">
          {messages.tutorials.backToIndex}
        </a>
      </footer>
    </article>
  </main>
  <Footer locale={locale} messages={messages} />
</Layout>
